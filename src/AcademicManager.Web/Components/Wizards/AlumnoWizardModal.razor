@namespace AcademicManager.Web.Components.Wizards
@using AcademicManager.Domain.Entities

@if (ShowWizard)
{
<div class="modal">
    <div class="modal-header">
        <h3>Alumno Wizard</h3>
        <button class="btn-close" @onclick="InternalCloseWizard">&times;</button>
    </div>
    <div class="modal-body">
        @if (EditingAlumno != null)
        {
            <div class="form-group">
                <label>Código</label>
                <input type="text" class="form-control" @bind="EditingAlumno.Codigo" />
            </div>
            <div class="form-group">
                <label>Nombres</label>
                <input type="text" class="form-control" @bind="EditingAlumno.Nombres" />
            </div>
            <div class="form-group">
                <label>Apellidos</label>
                <input type="text" class="form-control" @bind="EditingAlumno.Apellidos" />
            </div>
            <div class="form-group">
                <label>Fecha de Nacimiento</label>
                <input type="date" class="form-control" @bind="EditingAlumno.FechaNacimiento" />
            </div>
            <div class="form-group">
                <label>Género</label>
                <select class="form-control" @bind="EditingAlumno.Genero">
                    <option value="Masculino">Masculino</option>
                    <option value="Femenino">Femenino</option>
                </select>
            </div>
            <div class="form-group">
                <label>Dirección</label>
                <input type="text" class="form-control" @bind="EditingAlumno.Direccion" />
            </div>
            <div class="form-group">
                <label>Teléfono</label>
                <input type="text" class="form-control" @bind="EditingAlumno.Telefono" />
            </div>
            <div class="form-group">
                <label>Email</label>
                <input type="email" class="form-control" @bind="EditingAlumno.Email" />
            </div>
            <div class="form-group">
                <label>Nombre del Apoderado</label>
                <input type="text" class="form-control" @bind="EditingAlumno.NombreApoderado" />
            </div>
            <div class="form-group">
                <label>Teléfono del Apoderado</label>
                <input type="text" class="form-control" @bind="EditingAlumno.TelefonoApoderado" />
            </div>
            <div class="form-group">
                <label>Grado</label>
                <select class="form-control" @bind="EditingAlumno.GradoId" @bind:after="OnGradoChanged">
                    <option value="">Seleccionar Grado</option>
                    @foreach (var grado in Grados)
                    {
                        <option value="@grado.Id">@grado.Nombre</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label>Sección</label>
                <select class="form-control" @bind="EditingAlumno.SeccionId">
                    <option value="">Seleccionar Sección</option>
                    @foreach (var seccion in FilteredSecciones)
                    {
                        <option value="@seccion.Id">@seccion.Nombre</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label>
                    <input type="checkbox" @bind="EditingAlumno.Activo" /> Activo
                </label>
            </div>
        }

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="alert alert-danger">@ErrorMessage</div>
        }
    </div>
    <div class="modal-footer">
        <button class="btn btn-secondary" @onclick="InternalCloseWizard" disabled="@IsSubmitting">Cancelar</button>
        <button class="btn btn-primary" @onclick="HandleSave" disabled="@IsSubmitting">
            @if (IsSubmitting)
            {
                <span class="spinner spinner-sm me-2"></span>
                <span>Guardando...</span>
            }
            else
            {
                <span>Guardar</span>
            }
        </button>
    </div>
</div>
}

@code {
    [Parameter] public bool ShowWizard { get; set; }
    [Parameter] public EventCallback<bool> ShowWizardChanged { get; set; }
    [Parameter] public Alumno? EditingAlumno { get; set; }
    [Parameter] public bool IsSubmitting { get; set; }
    [Parameter] public string? ErrorMessage { get; set; }
    [Parameter] public List<Grado> Grados { get; set; } = new();
    [Parameter] public List<Seccion> AllSecciones { get; set; } = new();
    [Parameter] public List<Seccion> FilteredSecciones { get; set; } = new();

    [Parameter] public EventCallback SaveAlumnoAsync { get; set; }

    private async Task InternalCloseWizard()
    {
        ShowWizard = false;
        await ShowWizardChanged.InvokeAsync(ShowWizard);
    }

    private async Task HandleSave()
    {
        if (SaveAlumnoAsync.HasDelegate)
        {
            await SaveAlumnoAsync.InvokeAsync();
        }
    }

    private void OnGradoChanged()
    {
        if (EditingAlumno?.GradoId.HasValue == true)
        {
            FilteredSecciones = AllSecciones.Where(s => s.GradoId == EditingAlumno.GradoId.Value).ToList();
        }
        else
        {
            FilteredSecciones = new List<Seccion>();
        }
    }
}
