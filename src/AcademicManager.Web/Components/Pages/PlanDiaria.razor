@code {
    [Parameter] public int PlanMensualId { get; set; }

    private AcademicManager.Domain.Entities.PlanificacionMensual? planMensual;
    private List<AcademicManager.Domain.Entities.PlanificacionDiaria> planesDiarios = new();
    private AcademicManager.Domain.Entities.PlanificacionDiaria editingDia = new();

    private bool isLoading = true;
    private bool showForm = false;
    private bool isSubmitting = false;
    private bool isGeneratingAI = false;
    private string errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            planMensual = await MensualService.ObtenerPorIdAsync(PlanMensualId);
            planesDiarios = (await DiariaService.ObtenerPorPlanMensualAsync(PlanMensualId)).ToList();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ShowCreateForm()
    {
        // Sugerir próxima fecha laboral disponible
        var fechaSugerida = planesDiarios.Any()
            ? planesDiarios.Max(d => d.Fecha).AddDays(1)
            : DateTime.Today;

        editingDia = new AcademicManager.Domain.Entities.PlanificacionDiaria
        {
            PlanificacionMensualId = PlanMensualId,
            Fecha = fechaSugerida,
            TiempoInicioMinutos = 15,
            TiempoDesarrolloMinutos = 25,
            TiempoCierreMinutos = 10,
            Estado = "Borrador"
        };
        errorMessage = "";
        showForm = true;
    }

    private void EditarDiaria(AcademicManager.Domain.Entities.PlanificacionDiaria dia)
    {
        editingDia = new AcademicManager.Domain.Entities.PlanificacionDiaria
        {
            Id = dia.Id,
            PlanificacionMensualId = dia.PlanificacionMensualId,
            Fecha = dia.Fecha,
            IntencionPedagogica = dia.IntencionPedagogica,
            ActividadesInicio = dia.ActividadesInicio,
            TiempoInicioMinutos = dia.TiempoInicioMinutos,
            ActividadesDesarrollo = dia.ActividadesDesarrollo,
            TiempoDesarrolloMinutos = dia.TiempoDesarrolloMinutos,
            ActividadesCierre = dia.ActividadesCierre,
            TiempoCierreMinutos = dia.TiempoCierreMinutos,
            EstrategiasEnsenanza = dia.EstrategiasEnsenanza,
            OrganizacionEstudiantes = dia.OrganizacionEstudiantes,
            VocabularioDia = dia.VocabularioDia,
            Recursos = dia.Recursos,
            LecturasRecomendadas = dia.LecturasRecomendadas,
            Observaciones = dia.Observaciones,
            Estado = dia.Estado
        };
        errorMessage = "";
        showForm = true;
    }

    private void OnFechaChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var fecha))
            editingDia.Fecha = fecha;
    }

    private async Task GuardarDiaria()
    {
        try
        {
            isSubmitting = true;
            errorMessage = "";

            if (string.IsNullOrWhiteSpace(editingDia.IntencionPedagogica))
            {
                errorMessage = "La intención pedagógica es obligatoria.";
                return;
            }

            if (editingDia.Id == 0)
            {
                var (success, id, message) = await DiariaService.CrearAsync(editingDia);
                if (success)
                {
                    showForm = false;
                    await LoadData();
                }
                else
                {
                    errorMessage = message;
                }
            }
            else
            {
                var (success, message) = await DiariaService.ActualizarAsync(editingDia);
                if (success)
                {
                    showForm = false;
                    await LoadData();
                }
                else
                {
                    errorMessage = message;
                }
            }
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task EliminarDiaria(int id)
    {
        if (await JS.InvokeAsync<bool>("confirm", "¿Eliminar este plan diario?"))
        {
            var (success, msg) = await DiariaService.EliminarAsync(id);
            if (success) await LoadData();
        }
    }

    private async Task AutocompletarConIA()
    {
        if (string.IsNullOrWhiteSpace(editingDia.IntencionPedagogica))
        {
            errorMessage = "⚠️ Escribe primero la intención pedagógica para que la IA sepa de qué trata la clase.";
            return;
        }

        isGeneratingAI = true;
        errorMessage = "";
        StateHasChanged(); // Render loading state
        
        var temaMensual = planMensual?.TituloUnidad ?? "Unidad Escolar";
        var dict = await AiService.SugerirPlanDiarioEstructuradoAsync(editingDia.IntencionPedagogica, temaMensual);
        
        if (dict.ContainsKey("Error"))
        {
            errorMessage = dict["Error"];
        }
        else
        {
            if (dict.TryGetValue("inicio", out var vInit)) editingDia.ActividadesInicio = vInit;
            if (dict.TryGetValue("desarrollo", out var vDev)) editingDia.ActividadesDesarrollo = vDev;
            if (dict.TryGetValue("cierre", out var vEnd)) editingDia.ActividadesCierre = vEnd;
            if (dict.TryGetValue("estrategias", out var vEst)) editingDia.EstrategiasEnsenanza = vEst;
            if (dict.TryGetValue("organizacion", out var vOrg)) editingDia.OrganizacionEstudiantes = vOrg;
            if (dict.TryGetValue("vocabulario", out var vVoc)) editingDia.VocabularioDia = vVoc;
            if (dict.TryGetValue("recursos", out var vRec)) editingDia.Recursos = vRec;
            if (dict.TryGetValue("lecturas", out var vLec)) editingDia.LecturasRecomendadas = vLec;
        }
        
        isGeneratingAI = false;
    }

    private void CancelarForm()
    {
        showForm = false;
        errorMessage = "";
    }

    private async Task DownloadPdf(AcademicManager.Domain.Entities.PlanificacionDiaria plan)
    {
        var bytes = ExportService.GenerarPdfPlanDiario(plan);
        await JS.InvokeVoidAsync("downloadFileFromBase64", $"PlanDiaria_{plan.Fecha:yyyy-MM-dd}.pdf", Convert.ToBase64String(bytes));
    }

    private async Task DownloadWord(AcademicManager.Domain.Entities.PlanificacionDiaria plan)
    {
        var bytes = ExportService.GenerarWordPlanDiario(plan);
        await JS.InvokeVoidAsync("downloadFileFromBase64", $"PlanDiaria_{plan.Fecha:yyyy-MM-dd}.docx", Convert.ToBase64String(bytes));
    }

    // Helpers para barra de tiempo en formulario
    private int GetTotalForm() => editingDia.TiempoInicioMinutos + editingDia.TiempoDesarrolloMinutos + editingDia.TiempoCierreMinutos;
    private int GetPctInicio() => GetTotalForm() == 0 ? 0 : (int)Math.Round((double)editingDia.TiempoInicioMinutos / GetTotalForm() * 100);
    private int GetPctDesarrollo() => GetTotalForm() == 0 ? 0 : (int)Math.Round((double)editingDia.TiempoDesarrolloMinutos / GetTotalForm() * 100);
    private int GetPctCierre() => GetTotalForm() == 0 ? 0 : (int)Math.Round((double)editingDia.TiempoCierreMinutos / GetTotalForm() * 100);
}
