@page "/"
@using AcademicManager.Application.DTOs
@using Microsoft.AspNetCore.Authorization
@inject AcademicManager.Application.Services.AcademicWorkspaceService WorkspaceService
@inject IHttpContextAccessor HttpContextAccessor
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Inicio | AcademicManager</PageTitle>

@if (isLoading)
{
    <div class="ops-section">
        <div class="ops-empty">
            <div class="spinner"></div>
            <p>Cargando tu workspace academico...</p>
        </div>
    </div>
}
else if (!string.IsNullOrWhiteSpace(loadError))
{
    <div class="ops-section">
        <div class="ops-empty">
            <h3>No se pudo construir el panel principal</h3>
            <p>@loadError</p>
        </div>
    </div>
}
else if (snapshot is not null)
{
    <div class="ops-page">
        <section class="ops-hero ops-hero-tonal">
            <div class="ops-copy">
                <span class="ops-kicker">@snapshot.PeriodoActivo</span>
                <h2>@snapshot.Title</h2>
                <p>@snapshot.Subtitle</p>
                <div class="ops-filterbar">
                    <span class="ops-badge tone-success">@GetRoleLabel(snapshot.Rol)</span>
                    <span class="ops-badge tone-primary">@snapshot.Metrics.Count indicador(es)</span>
                    <span class="ops-badge tone-warning">@snapshot.Alerts.Count alerta(s)</span>
                </div>
            </div>

            <div class="ops-stack">
                @foreach (var alert in snapshot.Alerts.Take(3))
                {
                    <article class="ops-alert severity-@alert.Severity">
                        <div>
                            <strong>@alert.Title</strong>
                            <p>@alert.Description</p>
                        </div>
                        <a href="@alert.Href">@alert.LinkLabel</a>
                    </article>
                }
            </div>
        </section>

        <section class="ops-metric-grid">
            @foreach (var metric in snapshot.Metrics)
            {
                <article class="ops-metric-card tone-@metric.Tone">
                    <div class="metric-topline">
                        <span class="ops-kicker">@metric.Label</span>
                        <span class="ops-metric-chip">@metric.Icon</span>
                    </div>
                    <strong class="ops-metric-value">@metric.Value</strong>
                    <span>@metric.Detail</span>
                </article>
            }
        </section>

        <section class="ops-section">
            <div class="ops-section-head">
                <div>
                    <span class="ops-kicker">Acciones</span>
                    <h3>Lo que debes mover ahora</h3>
                </div>
            </div>

            <div class="ops-action-grid">
                @foreach (var action in snapshot.Actions)
                {
                    <a class="ops-action-card" href="@action.Href">
                        <span class="ops-badge tone-primary">@action.Icon</span>
                        <strong>@action.Title</strong>
                        <span>@action.Description</span>
                    </a>
                }
            </div>
        </section>

        @if (snapshot.Teachers.Any())
        {
            <section class="ops-section">
                <div class="ops-section-head">
                    <div>
                        <span class="ops-kicker">Docentes</span>
                        <h3>@(IsCoordinatorLike(snapshot.Rol) ? "Pulso docente" : "Mi posicion operativa")</h3>
                    </div>
                    <a href="/docentes" class="ops-badge tone-primary">Abrir modulo</a>
                </div>

                <div class="ops-card-grid">
                    @foreach (var teacher in snapshot.Teachers.Take(6))
                    {
                        <article class="ops-person-card">
                            <div class="ops-filterbar">
                                <strong>@teacher.NombreCompleto</strong>
                                <span class="ops-badge @GetToneClassForScore(teacher.Score)">@teacher.Score pts</span>
                            </div>
                            <span>@teacher.Especialidad</span>
                            <span>@teacher.CursosAsignados curso(s) · @teacher.EstudiantesAtendidos estudiante(s)</span>
                            <div class="ops-progress">
                                <span style="width:@teacher.Score%"></span>
                            </div>
                            <span>@teacher.RiesgoOperativo</span>
                            <span><strong>Siguiente paso:</strong> @teacher.ProximaAccion</span>
                        </article>
                    }
                </div>
            </section>
        }

        @if (snapshot.Students.Any())
        {
            <section class="ops-section">
                <div class="ops-section-head">
                    <div>
                        <span class="ops-kicker">Estudiantes</span>
                        <h3>@(IsTeacher(snapshot.Rol) ? "Cartera bajo tu acompanamiento" : "Seguimiento priorizado")</h3>
                    </div>
                    <a href="/alumnos" class="ops-badge tone-primary">Ver detalle</a>
                </div>

                <div class="ops-card-grid">
                    @foreach (var student in snapshot.Students.Take(8))
                    {
                        <article class="ops-person-card">
                            <div class="ops-filterbar">
                                <strong>@student.NombreCompleto</strong>
                                <span class="ops-badge @GetStudentTone(student.NivelSeguimiento)">@student.NivelSeguimiento</span>
                            </div>
                            <span>@student.GradoSeccion</span>
                            <span>@student.CursosActivos curso(s) · @student.EstadoAcademico</span>
                            <span><strong>Responsable:</strong> @student.Responsable</span>
                            <span><strong>Familia:</strong> @student.ContactoFamiliar</span>
                            <span>@student.Observacion</span>
                        </article>
                    }
                </div>
            </section>
        }

        @if (snapshot.Planning.Any())
        {
            <section class="ops-section">
                <div class="ops-section-head">
                    <div>
                        <span class="ops-kicker">Planificacion</span>
                        <h3>Estado del flujo pedagogico</h3>
                    </div>
                    <a href="/planificador" class="ops-badge tone-primary">Ir al planificador</a>
                </div>

                <div class="ops-card-grid">
                    @foreach (var plan in snapshot.Planning.Take(6))
                    {
                        <article class="ops-planning-card">
                            <div class="ops-filterbar">
                                <strong>@plan.CursoNombre</strong>
                                <span class="ops-badge @GetPlanningTone(plan.EstadoPrincipal)">@plan.EstadoPrincipal</span>
                            </div>
                            <span>@plan.CodigoCurso · @plan.DocenteLabel</span>
                            <span>@plan.SeccionLabel · @plan.EstudiantesImpactados estudiante(s)</span>
                            <div class="ops-progress">
                                <span style="width:@plan.Cobertura%"></span>
                            </div>
                            <span><strong>Cobertura:</strong> @plan.Cobertura%</span>
                            <span><strong>Proximo paso:</strong> @plan.ProximoPaso</span>
                        </article>
                    }
                </div>
            </section>
        }
    </div>
}

@code {
    private AcademicWorkspaceSnapshot? snapshot;
    private bool isLoading = true;
    private string loadError = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var session = HttpContextAccessor.HttpContext?.Session;
            var role = session?.GetString("UserRole");
            var docenteId = session?.GetInt32("DocenteId");
            var alumnoId = session?.GetInt32("AlumnoId");

            snapshot = await WorkspaceService.ObtenerPanelPrincipalAsync(role, docenteId, alumnoId);
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private static bool IsCoordinatorLike(string role) =>
        string.Equals(role, "Admin", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(role, "Coordinador", StringComparison.OrdinalIgnoreCase);

    private static bool IsTeacher(string role) =>
        string.Equals(role, "Docente", StringComparison.OrdinalIgnoreCase);

    private static string GetRoleLabel(string role) => role switch
    {
        "Admin" => "Administrador",
        "Coordinador" => "Coordinador",
        "Docente" => "Docente",
        "Alumno" => "Alumno",
        _ => "Operacion"
    };

    private static string GetToneClassForScore(int score) => score switch
    {
        >= 80 => "tone-success",
        >= 60 => "tone-warning",
        _ => "tone-danger"
    };

    private static string GetStudentTone(string level) => level switch
    {
        "Estable" => "tone-success",
        "En seguimiento" => "tone-primary",
        "Atencion" => "tone-warning",
        _ => "tone-danger"
    };

    private static string GetPlanningTone(string status) => status switch
    {
        "Aprobado" => "tone-success",
        "Por revisar" => "tone-warning",
        "Requiere ajustes" => "tone-danger",
        "En borrador" => "tone-primary",
        _ => "tone-danger"
    };
}
