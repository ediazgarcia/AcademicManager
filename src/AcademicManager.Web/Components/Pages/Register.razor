@page "/register"
@attribute [AllowAnonymous]
@layout EmptyLayout
@using Microsoft.AspNetCore.Authorization

<PageTitle>Registro | AcademicManager</PageTitle>

<div class="register-page-wrapper">
    <svg class="planets-animation" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1920 1080" preserveAspectRatio="xMidYMid slice">
        <defs>
            <radialGradient id="sunGradient2">
                <stop offset="0%" style="stop-color:#FDB813;stop-opacity:1" />
                <stop offset="100%" style="stop-color:#FF6B35;stop-opacity:1" />
            </radialGradient>
            <radialGradient id="earthGradient2">
                <stop offset="0%" style="stop-color:#4A90E2;stop-opacity:1" />
                <stop offset="100%" style="stop-color:#2E5C8A;stop-opacity:1" />
            </radialGradient>
            <filter id="glow2">
                <feGaussianBlur stdDeviation="2" result="coloredBlur"/>
                <feMerge>
                    <feMergeNode in="coloredBlur"/>
                    <feMergeNode in="SourceGraphic"/>
                </feMerge>
            </filter>
        </defs>
        <rect width="1920" height="1080" fill="#0a0e27"/>
        <g class="stars">
            <circle cx="100" cy="100" r="1.5" fill="white" opacity="0.8"/>
            <circle cx="300" cy="150" r="1" fill="white" opacity="0.6"/>
            <circle cx="500" cy="80" r="1.2" fill="white" opacity="0.7"/>
            <circle cx="700" cy="200" r="1" fill="white" opacity="0.5"/>
            <circle cx="900" cy="120" r="1.5" fill="white" opacity="0.8"/>
            <circle cx="1100" cy="180" r="1" fill="white" opacity="0.6"/>
            <circle cx="1300" cy="90" r="1.2" fill="white" opacity="0.7"/>
            <circle cx="1500" cy="160" r="1" fill="white" opacity="0.5"/>
            <circle cx="1700" cy="130" r="1.5" fill="white" opacity="0.8"/>
        </g>
        <circle cx="960" cy="540" r="80" fill="url(#sunGradient2)" filter="url(#glow2)"/>
        <circle cx="1320" cy="540" r="24" fill="url(#earthGradient2)"/>
    </svg>

    <div class="register-container">
        <div class="register-card">
            @if (IsSuccess)
            {
                <div class="register-success">
                    <div class="success-icon">✓</div>
                    <h3>¡Solicitud Enviada!</h3>
                    <p>Un administrador la revisará pronto.</p>
                    <a href="/login" class="btn btn-primary btn-sm">Ir al Login</a>
                </div>
            }
            else
            {
                <div class="register-header-mini">
                    <div class="register-avatar-mini">
                        <span>🎓</span>
                    </div>
                    <h2>Registrarse</h2>
                </div>

                <form method="post" action="/Account/Register" class="register-form-mini">
                    @if (!string.IsNullOrEmpty(ErrorMessage))
                    {
                        <div class="alert alert-error">@ErrorMessage</div>
                    }

                    <div class="form-row-mini">
                        <div class="form-group-mini">
                            <label>Usuario</label>
                            <input type="text" name="username" class="form-control" placeholder="Usuario" required />
                        </div>
                        <div class="form-group-mini">
                            <label>Email</label>
                            <input type="email" name="email" class="form-control" placeholder="Email" />
                        </div>
                    </div>

                    <div class="form-group-mini">
                        <label>Contraseña</label>
                        <input type="password" name="password" class="form-control" placeholder="Mínimo 8 caracteres, mayúscula, minúscula y número" required />
                    </div>

                    <div class="form-group-mini">
                        <label>Tipo</label>
                        <select name="role" class="form-control" required>
                            <option value="">Seleccionar...</option>
                            <option value="Alumno">Alumno</option>
                            <option value="Docente">Docente</option>
                        </select>
                    </div>

                    <button type="submit" class="btn btn-primary btn-block">
                        Registrarse
                    </button>
                </form>

                <div class="register-footer-mini">
                    <span>¿Ya tienes cuenta?</span>
                    <a href="/login" data-enhance-nav="false">Iniciar sesión</a>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "success")]
    public bool IsSuccess { get; set; }

    [SupplyParameterFromQuery(Name = "error")]
    public string? ErrorMessage { get; set; }
}
