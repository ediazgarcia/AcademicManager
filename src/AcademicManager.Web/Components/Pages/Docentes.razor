@page "/docentes"
@attribute [Authorize(Roles = "Admin,Coordinador")]
@using AcademicManager.Application.DTOs
@using AcademicManager.Web.Components.Common
@using AcademicManager.Web.Components.Forms
@using Microsoft.AspNetCore.Authorization
@inject AcademicManager.Application.Services.AcademicWorkspaceService WorkspaceService
@inject AcademicManager.Application.Services.DocenteCursoService DocenteCursoService
@inject AcademicManager.Application.Services.CursoService CursoService
@inject AcademicManager.Application.Services.DocenteService DocenteService
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Docentes | AcademicManager</PageTitle>

<div class="ops-page">
    <section class="ops-hero">
        <div class="ops-copy">
            <span class="ops-kicker">Coordinacion docente</span>
            <h2>Seguimiento operativo del profesorado</h2>
            <p>La vista combina carga academica, cobertura de planificacion y acompanamiento para que el coordinador actue con contexto y no solo por intuicion.</p>
        </div>

        <div class="ops-stack">
            <article class="ops-alert severity-warning">
                <div>
                    <strong>@docentesSinCarga docente(s) sin carga</strong>
                    <p>Necesitan asignacion de cursos o redistribucion institucional.</p>
                </div>
                <a href="#tabla-docentes">Ir a la lista</a>
            </article>
            <article class="ops-alert severity-info">
                <div>
                    <strong>@planesPendientes plan(es) enviados</strong>
                    <p>Esperan revision desde coordinacion.</p>
                </div>
                <a href="/planificador">Abrir flujo</a>
            </article>
        </div>
    </section>

    <section class="ops-metric-grid">
        <article class="ops-metric-card tone-primary">
            <div class="metric-topline">
                <span class="ops-kicker">Equipo</span>
                <span class="ops-metric-chip">DO</span>
            </div>
            <strong class="ops-metric-value">@teacherSummaries.Count</strong>
            <span>Docentes visibles en la operacion actual.</span>
        </article>
        <article class="ops-metric-card tone-success">
            <div class="metric-topline">
                <span class="ops-kicker">Promedio</span>
                <span class="ops-metric-chip">SC</span>
            </div>
            <strong class="ops-metric-value">@promedioDesempeno</strong>
            <span>Puntaje medio de salud operativa.</span>
        </article>
        <article class="ops-metric-card tone-warning">
            <div class="metric-topline">
                <span class="ops-kicker">Revision</span>
                <span class="ops-metric-chip">RV</span>
            </div>
            <strong class="ops-metric-value">@planesPendientes</strong>
            <span>Planes que todavia esperan accion de coordinacion.</span>
        </article>
        <article class="ops-metric-card tone-danger">
            <div class="metric-topline">
                <span class="ops-kicker">Prioridad</span>
                <span class="ops-metric-chip">AT</span>
            </div>
            <strong class="ops-metric-value">@docentesPrioritarios</strong>
            <span>Docentes que conviene acompanar esta semana.</span>
        </article>
    </section>

    <section class="ops-section">
        <div class="ops-section-head">
            <div>
                <span class="ops-kicker">Pulso docente</span>
                <h3>Lectura rapida del desempeno</h3>
            </div>
            <div class="ops-filterbar">
                @foreach (var filter in performanceFilters)
                {
                    <button type="button"
                            class="ops-pill @(performanceFilter == filter ? "active" : string.Empty)"
                            @onclick="() => SetPerformanceFilter(filter)">
                        @filter
                    </button>
                }
            </div>
        </div>

        <div class="ops-card-grid">
            @foreach (var docente in HighlightedDocentes)
            {
                var summary = GetSummary(docente.Id);
                <article class="ops-person-card">
                    <div class="ops-filterbar">
                        <strong>@docente.Apellidos, @docente.Nombres</strong>
                        @if (summary is not null)
                        {
                            <span class="ops-badge @GetScoreTone(summary.Score)">@summary.Score pts</span>
                        }
                    </div>
                    <span>@docente.Especialidad</span>
                    @if (summary is not null)
                    {
                        <span>@summary.CursosAsignados curso(s) · @summary.EstudiantesAtendidos estudiante(s)</span>
                        <div class="ops-progress">
                            <span style="width:@summary.Score%"></span>
                        </div>
                        <span><strong>@summary.NivelDesempeno</strong> · @summary.RiesgoOperativo</span>
                        <span>@summary.ProximaAccion</span>
                    }
                </article>
            }
        </div>
    </section>

    <section id="tabla-docentes" class="ops-section">
        <div class="ops-section-head">
            <div>
                <span class="ops-kicker">Gestion</span>
                <h3>Roster docente</h3>
            </div>
            <div class="ops-filterbar">
                <div class="ops-search">
                    <input type="text"
                           placeholder="Buscar por nombre, codigo o especialidad..."
                           @bind="searchTerm"
                           @bind:event="oninput"
                           @onkeyup="OnSearchChanged" />
                </div>
                <button class="btn btn-primary" @onclick="ShowCreateModal">
                    <span>+ Nuevo docente</span>
                </button>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(pageError))
        {
            <div class="alert alert-error">@pageError</div>
        }

        <div class="ops-table-shell">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Docente</th>
                        <th>Especialidad</th>
                        <th>Carga</th>
                        <th>Operacion</th>
                        <th>Contacto</th>
                        <th class="text-right">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (isLoading)
                    {
                        <tr>
                            <td colspan="6" class="text-center p-3">
                                <div class="spinner"></div>
                            </td>
                        </tr>
                    }
                    else if (!PaginatedDocentes.Any())
                    {
                        <tr>
                            <td colspan="6">
                                <div class="ops-empty">No hay docentes para el filtro actual.</div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var docente in PaginatedDocentes)
                        {
                            var summary = GetSummary(docente.Id);
                            <tr>
                                <td>
                                    <strong>@docente.Apellidos, @docente.Nombres</strong>
                                    <div class="text-muted">@docente.Codigo</div>
                                </td>
                                <td>@docente.Especialidad</td>
                                <td>
                                    @if (summary is not null)
                                    {
                                        <span>@summary.CursosAsignados curso(s)</span>
                                        <br />
                                        <small>@summary.EstudiantesAtendidos estudiante(s)</small>
                                    }
                                </td>
                                <td>
                                    @if (summary is not null)
                                    {
                                        <span class="ops-badge @GetScoreTone(summary.Score)">@summary.NivelDesempeno</span>
                                        <br />
                                        <small>@summary.ProximaAccion</small>
                                    }
                                </td>
                                <td>
                                    <small>@docente.Email<br />@docente.Telefono</small>
                                </td>
                                <td class="text-right">
                                    <button class="btn btn-ghost btn-sm" @onclick="() => Edit(docente)" title="Editar">✏️</button>
                                    <button class="btn btn-ghost btn-sm" @onclick="() => OpenAssignmentModal(docente)" title="Asignar cursos">📘</button>
                                    <button class="btn btn-ghost btn-sm text-danger" @onclick="() => Delete(docente.Id)" title="Eliminar">🗑️</button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        @if (TotalItems > 0)
        {
            <Pagination CurrentPage="@currentPage"
                        PageSize="@pageSize"
                        TotalItems="@TotalItems"
                        OnPageChanged="HandlePageChanged"
                        OnPageSizeChanged="HandlePageSizeChanged" />
        }
    </section>
</div>

@if (showModal)
{
    <div class="modal-overlay" @onclick="@(() => { if (!isSubmitting) CloseModal(); })">
        <div class="modal modal-lg" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>@(editingDocente.Id == 0 ? "Nuevo docente" : "Editar docente")</h3>
                <button class="btn btn-ghost btn-icon" @onclick="CloseModal" disabled="@isSubmitting">✕</button>
            </div>

            <CustomEditForm Model="editingDocente" OnValidSubmit="Save" FormName="DocenteForm">
                <DataAnnotationsValidator />

                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-error">@errorMessage</div>
                    }

                    <div class="form-grid">
                        <div class="form-group">
                            <label>Código</label>
                            <InputText class="form-control" @bind-Value="editingDocente.Codigo" />
                        </div>
                        <div class="form-group">
                            <label>Fecha de nacimiento</label>
                            <InputDate class="form-control" @bind-Value="editingDocente.FechaNacimiento" />
                        </div>
                    </div>

                    <div class="form-grid">
                        <div class="form-group">
                            <label>Nombres</label>
                            <InputText class="form-control" @bind-Value="editingDocente.Nombres" />
                        </div>
                        <div class="form-group">
                            <label>Apellidos</label>
                            <InputText class="form-control" @bind-Value="editingDocente.Apellidos" />
                        </div>
                    </div>

                    <div class="form-grid">
                        <div class="form-group">
                            <label>Especialidad</label>
                            <InputText class="form-control" @bind-Value="editingDocente.Especialidad" />
                        </div>
                        <div class="form-group">
                            <label>Fecha de contratacion</label>
                            <InputDate class="form-control" @bind-Value="editingDocente.FechaContratacion" />
                        </div>
                    </div>

                    <div class="form-grid">
                        <div class="form-group">
                            <label>Telefono</label>
                            <InputText class="form-control" @bind-Value="editingDocente.Telefono" />
                        </div>
                        <div class="form-group">
                            <label>Email</label>
                            <InputText class="form-control" @bind-Value="editingDocente.Email" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Direccion</label>
                        <InputText class="form-control" @bind-Value="editingDocente.Direccion" />
                    </div>

                    <div class="form-group mt-3">
                        <label class="d-flex align-center gap-1">
                            <InputCheckbox @bind-Value="editingDocente.Activo" />
                            <span>Docente activo</span>
                        </label>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal" disabled="@isSubmitting">Cancelar</button>
                    <button type="submit" class="btn btn-primary" disabled="@isSubmitting">Guardar</button>
                </div>
            </CustomEditForm>
        </div>
    </div>
}

@if (showAssignmentModal && selectedAssignmentDocente is not null)
{
    <div class="modal-overlay" @onclick="@(() => { if (!isAssignmentSubmitting) CloseAssignmentModal(); })">
        <div class="modal modal-lg" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>Cursos de @selectedAssignmentDocente.Apellidos, @selectedAssignmentDocente.Nombres</h3>
                <button class="btn btn-ghost btn-icon" @onclick="CloseAssignmentModal" disabled="@isAssignmentSubmitting">✕</button>
            </div>

            <div class="modal-body">
                @if (!string.IsNullOrWhiteSpace(assignmentErrorMessage))
                {
                    <div class="alert alert-error">@assignmentErrorMessage</div>
                }

                <div class="form-row">
                    <div class="form-group" style="flex: 1;">
                        <label>Curso disponible</label>
                        <select class="form-control" @bind="selectedCursoId" disabled="@isAssignmentSubmitting">
                            <option value="0">Seleccionar curso</option>
                            @foreach (var curso in CursosDisponiblesParaAsignar)
                            {
                                <option value="@curso.Id">@curso.Codigo - @curso.Nombre</option>
                            }
                        </select>
                    </div>
                    <div class="form-group d-flex align-end">
                        <button class="btn btn-primary"
                                @onclick="AsignarCursoSeleccionado"
                                disabled="@(isAssignmentSubmitting || selectedCursoId == 0)">
                            + Asignar
                        </button>
                    </div>
                </div>

                <div class="ops-table-shell">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Código</th>
                                <th>Curso</th>
                                <th class="text-right">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!cursosAsignados.Any())
                            {
                                <tr>
                                    <td colspan="3">
                                        <div class="ops-empty">Este docente aun no tiene cursos asignados.</div>
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var curso in cursosAsignados)
                                {
                                    <tr>
                                        <td>@curso.Codigo</td>
                                        <td>@curso.Nombre</td>
                                        <td class="text-right">
                                            <button class="btn btn-ghost btn-sm text-danger"
                                                    @onclick="() => DesasignarCurso(curso.Id)"
                                                    disabled="@isAssignmentSubmitting">
                                                ❌
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseAssignmentModal" disabled="@isAssignmentSubmitting">Cerrar</button>
            </div>
        </div>
    </div>
}

<Modal Show="showConfirmModal"
       Title="@confirmModalTitle"
       Size="sm"
       IsSubmitting="@isConfirmSubmitting"
       ShowChanged="OnConfirmModalChanged">
    <ChildContent>
        <div class="confirm-delete">
            <div class="confirm-icon">⚠️</div>
            <div class="confirm-message">
                <p>@confirmModalMessage</p>
            </div>
        </div>
    </ChildContent>
    <FooterContent>
        <button class="btn btn-secondary" @onclick="CancelConfirmActionAsync" disabled="@isConfirmSubmitting">Cancelar</button>
        <button class="btn btn-danger" @onclick="ExecuteConfirmActionAsync" disabled="@isConfirmSubmitting">Eliminar</button>
    </FooterContent>
</Modal>

@code {
    private readonly string[] performanceFilters = ["Todos", "Prioritario", "Consistente", "Sobresaliente"];

    private List<AcademicManager.Domain.Entities.Docente> allDocentes = new();
    private List<TeacherPerformanceSummary> teacherSummaries = new();
    private AcademicManager.Domain.Entities.Docente editingDocente = new();

    private bool showModal;
    private bool showAssignmentModal;
    private bool showConfirmModal;
    private bool isLoading = true;
    private bool isSubmitting;
    private bool isAssignmentSubmitting;
    private bool isConfirmSubmitting;
    private string searchTerm = string.Empty;
    private string performanceFilter = "Todos";
    private string errorMessage = string.Empty;
    private string assignmentErrorMessage = string.Empty;
    private string pageError = string.Empty;
    private int selectedCursoId;
    private AcademicManager.Domain.Entities.Docente? selectedAssignmentDocente;
    private List<AcademicManager.Domain.Entities.Curso> cursosDisponibles = new();
    private List<AcademicManager.Domain.Entities.Curso> cursosAsignados = new();
    private string confirmModalTitle = string.Empty;
    private string confirmModalMessage = string.Empty;
    private Func<Task>? pendingConfirmAction;

    private int currentPage = 1;
    private int pageSize = 10;

    private int promedioDesempeno => teacherSummaries.Any() ? (int)Math.Round(teacherSummaries.Average(item => item.Score)) : 0;
    private int planesPendientes => teacherSummaries.Sum(item => item.PlanesPendientes);
    private int docentesSinCarga => teacherSummaries.Count(item => item.CursosAsignados == 0);
    private int docentesPrioritarios => teacherSummaries.Count(item => item.Score < 60);

    private IEnumerable<AcademicManager.Domain.Entities.Docente> FilteredDocentes =>
        allDocentes
            .Where(docente =>
                string.IsNullOrWhiteSpace(searchTerm) ||
                docente.Nombres.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                docente.Apellidos.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                docente.Codigo.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                docente.Especialidad.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
            .Where(MatchesPerformanceFilter);

    private IEnumerable<AcademicManager.Domain.Entities.Docente> HighlightedDocentes => FilteredDocentes.Take(6);

    private int TotalItems => FilteredDocentes.Count();

    private IEnumerable<AcademicManager.Domain.Entities.Docente> PaginatedDocentes =>
        FilteredDocentes.Skip((currentPage - 1) * pageSize).Take(pageSize);

    private IEnumerable<AcademicManager.Domain.Entities.Curso> CursosDisponiblesParaAsignar =>
        cursosDisponibles.Where(curso => !cursosAsignados.Any(asignado => asignado.Id == curso.Id));

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        pageError = string.Empty;

        try
        {
            var docentesTask = DocenteService.ObtenerTodosAsync();
            var summariesTask = WorkspaceService.ObtenerResumenDocentesAsync();

            await Task.WhenAll(docentesTask, summariesTask);

            allDocentes = (await docentesTask).ToList();
            teacherSummaries = (await summariesTask).ToList();
        }
        catch (Exception ex)
        {
            pageError = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private TeacherPerformanceSummary? GetSummary(int docenteId) =>
        teacherSummaries.FirstOrDefault(item => item.DocenteId == docenteId);

    private bool MatchesPerformanceFilter(AcademicManager.Domain.Entities.Docente docente)
    {
        var summary = GetSummary(docente.Id);
        if (summary is null || performanceFilter == "Todos")
        {
            return true;
        }

        return performanceFilter switch
        {
            "Prioritario" => summary.Score < 60,
            "Consistente" => summary.Score >= 60 && summary.Score < 85,
            "Sobresaliente" => summary.Score >= 85,
            _ => true
        };
    }

    private void SetPerformanceFilter(string filter)
    {
        performanceFilter = filter;
        currentPage = 1;
    }

    private void OnSearchChanged() => currentPage = 1;

    private Task HandlePageChanged(int newPage)
    {
        currentPage = newPage;
        return Task.CompletedTask;
    }

    private Task HandlePageSizeChanged(int newSize)
    {
        pageSize = newSize;
        currentPage = 1;
        return Task.CompletedTask;
    }

    private void ShowCreateModal()
    {
        editingDocente = new AcademicManager.Domain.Entities.Docente
        {
            FechaContratacion = DateTime.Today,
            FechaNacimiento = DateTime.Today.AddYears(-25),
            Activo = true
        };
        errorMessage = string.Empty;
        showModal = true;
    }

    private void Edit(AcademicManager.Domain.Entities.Docente item)
    {
        editingDocente = new AcademicManager.Domain.Entities.Docente
        {
            Id = item.Id,
            Codigo = item.Codigo,
            Nombres = item.Nombres,
            Apellidos = item.Apellidos,
            FechaNacimiento = item.FechaNacimiento,
            Genero = item.Genero,
            Especialidad = item.Especialidad,
            Telefono = item.Telefono,
            Email = item.Email,
            Direccion = item.Direccion,
            FechaContratacion = item.FechaContratacion,
            Activo = item.Activo
        };
        errorMessage = string.Empty;
        showModal = true;
    }

    private void CloseModal()
    {
        if (!isSubmitting)
        {
            showModal = false;
            errorMessage = string.Empty;
        }
    }

    private async Task Save()
    {
        try
        {
            isSubmitting = true;
            errorMessage = string.Empty;

            if (editingDocente.Id == 0)
            {
                await DocenteService.CrearAsync(editingDocente);
            }
            else
            {
                await DocenteService.ActualizarAsync(editingDocente);
            }

            showModal = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task OpenAssignmentModal(AcademicManager.Domain.Entities.Docente docente)
    {
        selectedAssignmentDocente = docente;
        showAssignmentModal = true;
        assignmentErrorMessage = string.Empty;
        selectedCursoId = 0;
        await LoadAssignmentDataAsync();
    }

    private void CloseAssignmentModal()
    {
        if (isAssignmentSubmitting)
        {
            return;
        }

        showAssignmentModal = false;
        selectedAssignmentDocente = null;
        assignmentErrorMessage = string.Empty;
        selectedCursoId = 0;
        cursosAsignados.Clear();
    }

    private async Task LoadAssignmentDataAsync()
    {
        if (selectedAssignmentDocente is null)
        {
            return;
        }

        cursosDisponibles = (await CursoService.ObtenerTodosAsync())
            .Where(curso => curso.Activo)
            .OrderBy(curso => curso.Nombre)
            .ToList();

        cursosAsignados = (await DocenteCursoService.ObtenerCursosPorDocenteAsync(selectedAssignmentDocente.Id))
            .OrderBy(curso => curso.Nombre)
            .ToList();
    }

    private async Task AsignarCursoSeleccionado()
    {
        if (selectedAssignmentDocente is null || selectedCursoId == 0)
        {
            return;
        }

        try
        {
            isAssignmentSubmitting = true;
            assignmentErrorMessage = string.Empty;
            await DocenteCursoService.AsignarDocenteAsync(selectedAssignmentDocente.Id, selectedCursoId);
            selectedCursoId = 0;
            await LoadAssignmentDataAsync();
            await LoadData();
        }
        catch (Exception ex)
        {
            assignmentErrorMessage = ex.Message;
        }
        finally
        {
            isAssignmentSubmitting = false;
        }
    }

    private async Task DesasignarCurso(int cursoId)
    {
        if (selectedAssignmentDocente is null)
        {
            return;
        }

        try
        {
            isAssignmentSubmitting = true;
            assignmentErrorMessage = string.Empty;
            await DocenteCursoService.DesasignarDocenteAsync(selectedAssignmentDocente.Id, cursoId);
            await LoadAssignmentDataAsync();
            await LoadData();
        }
        catch (Exception ex)
        {
            assignmentErrorMessage = ex.Message;
        }
        finally
        {
            isAssignmentSubmitting = false;
        }
    }

    private Task Delete(int id)
    {
        confirmModalTitle = "Eliminar docente";
        confirmModalMessage = "Esta accion eliminara el docente y sus asignaciones de cursos.";
        pendingConfirmAction = () => DeleteAsync(id);
        showConfirmModal = true;
        return Task.CompletedTask;
    }

    private async Task DeleteAsync(int id)
    {
        await DocenteService.EliminarAsync(id);
        await LoadData();
    }

    private async Task ExecuteConfirmActionAsync()
    {
        if (pendingConfirmAction is null || isConfirmSubmitting)
        {
            return;
        }

        try
        {
            isConfirmSubmitting = true;
            await pendingConfirmAction();
            showConfirmModal = false;
            pendingConfirmAction = null;
        }
        catch (Exception ex)
        {
            pageError = ex.Message;
        }
        finally
        {
            isConfirmSubmitting = false;
        }
    }

    private Task CancelConfirmActionAsync()
    {
        if (!isConfirmSubmitting)
        {
            showConfirmModal = false;
            pendingConfirmAction = null;
        }

        return Task.CompletedTask;
    }

    private Task OnConfirmModalChanged(bool show)
    {
        if (!show && !isConfirmSubmitting)
        {
            showConfirmModal = false;
            pendingConfirmAction = null;
        }

        return Task.CompletedTask;
    }

    private static string GetScoreTone(int score) => score switch
    {
        >= 85 => "tone-success",
        >= 60 => "tone-warning",
        _ => "tone-danger"
    };
}
