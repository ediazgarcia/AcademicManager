@page "/profesores/plantillas"
@attribute [Authorize(Roles = "Admin,Docente")]
@using AcademicManager.Application.DTOs
@using AcademicManager.Application.Services
@using Microsoft.AspNetCore.Authorization
@inject FeedbackTemplateService TemplateService
@inject ILogger<FeedbackTemplates> Logger
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Plantillas de Retroalimentación | AcademicManager</PageTitle>

<div class="ops-page">
    @if (isLoading)
    {
        <div class="ops-empty">
            <div class="spinner"></div>
            <p>Cargando plantillas...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-error">
            <strong>Error:</strong> @errorMessage
        </div>
    }
    else
    {
        @* Hero Section *@
        <section class="ops-hero">
            <div class="ops-copy">
                <span class="ops-kicker">Biblioteca</span>
                <h2>Plantillas de Retroalimentación</h2>
                <p>Crea y gestiona comentarios reutilizables para agilizar el proceso de calificación.</p>
            </div>

            <div class="ops-stack">
                <article class="ops-alert severity-info">
                    <div>
                        <strong>@templates.Count plantilla(s) guardada(s)</strong>
                        <p>Listas para usar en tus calificaciones.</p>
                    </div>
                </article>
            </div>
        </section>

        @* Filters *@
        <section class="ops-section">
            <div class="template-filters">
                <div class="filter-group">
                    <input type="text"
                           class="form-control"
                           placeholder="Buscar plantillas..."
                           @bind="searchTerm"
                           @bind:event="oninput" />
                </div>

                <div class="filter-group">
                    <select class="form-control" @onchange="OnSubjectChanged">
                        <option value="">-- Todas las materias --</option>
                        @foreach (var subject in GetUniqueSujects())
                        {
                            <option value="@subject" selected="@(selectedSubject == subject)">@subject</option>
                        }
                    </select>
                </div>

                <button type="button" class="btn btn-primary" @onclick="ShowCreateModal">
                    + Nueva Plantilla
                </button>
            </div>
        </section>

        @* Templates List *@
        <section class="ops-section">
            <div class="templates-grid">
                @if (!FilteredTemplates.Any())
                {
                    <div class="ops-empty" style="grid-column: 1 / -1;">
                        <p>No hay plantillas disponibles con los filtros seleccionados.</p>
                    </div>
                }
                else
                {
                    @foreach (var template in FilteredTemplates)
                    {
                        <div class="template-card">
                            <div class="card-actions">
                                <button type="button"
                                        class="btn-icon btn-edit"
                                        @onclick="() => EditTemplate(template)"
                                        title="Editar">✏️</button>
                                <button type="button"
                                        class="btn-icon btn-delete"
                                        @onclick="() => DeleteTemplate(template.Id)"
                                        title="Eliminar">🗑️</button>
                            </div>

                            <div class="card-header">
                                <h4>@template.Titulo</h4>
                                @if (!string.IsNullOrEmpty(template.Materia))
                                {
                                    <span class="subject-badge">@template.Materia</span>
                                }
                            </div>

                            <div class="card-body">
                                <p class="template-content">@template.Contenido</p>
                            </div>

                            <div class="card-footer">
                                <span class="template-status">
                                    @if (template.Activa)
                                    {
                                        <span class="status-active">✓ Activa</span>
                                    }
                                    else
                                    {
                                        <span class="status-inactive">✗ Inactiva</span>
                                    }
                                </span>
                                <button type="button"
                                        class="btn btn-sm btn-secondary"
                                        @onclick="() => CopyTemplate(template)">
                                    📋 Copiar
                                </button>
                            </div>
                        </div>
                    }
                }
            </div>
        </section>
    }
</div>

@* Create/Edit Modal *@
@if (showModal)
{
    <div class="modal-overlay" @onclick="@(() => { if (!isSubmitting) CloseModal(); })">
        <div class="modal modal-lg" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>@(editingTemplate.Id == 0 ? "Nueva Plantilla" : "Editar Plantilla")</h3>
                <button class="btn-close" @onclick="CloseModal" disabled="@isSubmitting">✕</button>
            </div>

            <div class="modal-body">
                @if (!string.IsNullOrEmpty(modalError))
                {
                    <div class="alert alert-error">@modalError</div>
                }

                <div class="form-group">
                    <label>Título</label>
                    <input type="text"
                           class="form-control"
                           @bind="editingTemplate.Titulo"
                           placeholder="Ej: Excelente trabajo" />
                </div>

                <div class="form-group">
                    <label>Materia (opcional)</label>
                    <input type="text"
                           class="form-control"
                           @bind="editingTemplate.Materia"
                           placeholder="Ej: Matemáticas" />
                </div>

                <div class="form-group">
                    <label>Contenido</label>
                    <textarea class="form-control textarea-lg"
                              @bind="editingTemplate.Contenido"
                              placeholder="Escribe el comentario de retroalimentación..."></textarea>
                </div>

                <div class="form-group">
                    <label>
                        <input type="checkbox" @bind="editingTemplate.Activa" />
                        <span>Plantilla activa</span>
                    </label>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" @onclick="CloseModal" disabled="@isSubmitting">
                    Cancelar
                </button>
                <button type="button" class="btn btn-primary" @onclick="SaveTemplate" disabled="@isSubmitting">
                    @if (isSubmitting)
                    {
                        <span>Guardando...</span>
                    }
                    else
                    {
                        <span>Guardar</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private bool isSubmitting = false;
    private bool showModal = false;
    private string errorMessage = string.Empty;
    private string modalError = string.Empty;
    private string searchTerm = string.Empty;
    private string selectedSubject = string.Empty;

    private List<FeedbackTemplateDto> templates = new();
    private FeedbackTemplateDto editingTemplate = new();

    private IEnumerable<FeedbackTemplateDto> FilteredTemplates =>
        templates
            .Where(t => string.IsNullOrEmpty(searchTerm) ||
                       t.Titulo.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                       t.Contenido.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
            .Where(t => string.IsNullOrEmpty(selectedSubject) || t.Materia == selectedSubject);

    protected override async Task OnInitializedAsync()
    {
        await LoadTemplates();
    }

    private async Task LoadTemplates()
    {
        try
        {
            isLoading = true;
            errorMessage = string.Empty;

            // Load templates from service
            // Placeholder - would be loaded from TemplateService
            templates = new();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading templates");
            errorMessage = $"Error cargando plantillas: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private List<string> GetUniqueSujects()
    {
        return templates
            .Where(t => !string.IsNullOrEmpty(t.Materia))
            .Select(t => t.Materia)
            .Distinct()
            .OrderBy(s => s)
            .ToList();
    }

    private void OnSubjectChanged(ChangeEventArgs e)
    {
        selectedSubject = e.Value?.ToString() ?? string.Empty;
    }

    private void ShowCreateModal()
    {
        editingTemplate = new FeedbackTemplateDto { Activa = true };
        modalError = string.Empty;
        showModal = true;
    }

    private void EditTemplate(FeedbackTemplateDto template)
    {
        editingTemplate = new FeedbackTemplateDto
        {
            Id = template.Id,
            Titulo = template.Titulo,
            Contenido = template.Contenido,
            Materia = template.Materia,
            Activa = template.Activa
        };
        modalError = string.Empty;
        showModal = true;
    }

    private void CloseModal()
    {
        if (!isSubmitting)
        {
            showModal = false;
            editingTemplate = new();
            modalError = string.Empty;
        }
    }

    private async Task SaveTemplate()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(editingTemplate.Titulo))
            {
                modalError = "El título es requerido";
                return;
            }

            if (string.IsNullOrWhiteSpace(editingTemplate.Contenido))
            {
                modalError = "El contenido es requerido";
                return;
            }

            isSubmitting = true;
            modalError = string.Empty;

            if (editingTemplate.Id == 0)
            {
                // Create new template via service
                // await TemplateService.CreateTemplateAsync(editingTemplate);
            }
            else
            {
                // Update existing template via service
                // await TemplateService.UpdateTemplateAsync(editingTemplate);
            }

            await LoadTemplates();
            showModal = false;
            editingTemplate = new();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving template");
            modalError = $"Error guardando plantilla: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task DeleteTemplate(int templateId)
    {
        try
        {
            if (await JSRuntime.InvokeAsync<bool>("confirm", "¿Eliminar esta plantilla?"))
            {
                // Delete template via service
                // await TemplateService.DeleteTemplateAsync(templateId);
                await LoadTemplates();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error deleting template");
            errorMessage = $"Error eliminando plantilla: {ex.Message}";
        }
    }

    private async Task CopyTemplate(FeedbackTemplateDto template)
    {
        try
        {
            // Copy to clipboard
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", template.Contenido);
            Logger.LogInformation("Template copied to clipboard");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error copying template");
        }
    }

    [Inject]
    public IJSRuntime JSRuntime { get; set; }

    public class FeedbackTemplateDto
    {
        public int Id { get; set; }
        public string Titulo { get; set; } = string.Empty;
        public string Contenido { get; set; } = string.Empty;
        public string Materia { get; set; } = string.Empty;
        public bool Activa { get; set; }
    }
}

