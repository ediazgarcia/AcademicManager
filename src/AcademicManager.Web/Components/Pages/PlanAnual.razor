}

@@media (max-width: 640px) {
    .plan-header { flex-direction: column; gap: 1rem; }
    .form-grid-2 { grid-template-columns: 1fr; }
}
</style>

@code {
    [Parameter] public int CursoId { get; set; }
    
    private List<AcademicManager.Domain.Entities.Planificacion> planes = new();
    private List<AcademicManager.Domain.Entities.Seccion> secciones = new();
    private List<AcademicManager.Domain.Entities.PeriodoAcademico> periodos = new();
    private AcademicManager.Domain.Entities.Planificacion editingPlan = new();
    
    private string cursoNombre = "";
    private bool isLoading = true;
    private bool showForm = false;
    private bool isSubmitting = false;
    private bool isGeneratingAI = false;
    private string errorMessage = "";
    private string successMessage = "";
    private int selectedPlanId = 0;
    private int currentDocenteId = 0;
    private string currentRole = "";
    private bool canCreatePlan = true;
    private string sessionErrorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        var session = HttpContextAccessor.HttpContext?.Session;
        currentRole = session?.GetString("UserRole") ?? "";
        currentDocenteId = session?.GetInt32("DocenteId") ?? 0;

        await ValidateCurrentDocenteAsync();
        
        await LoadMetadata();
        await LoadData();
    }

    private async Task ValidateCurrentDocenteAsync()
    {
        if (currentDocenteId <= 0)
        {
            canCreatePlan = false;
            sessionErrorMessage = "No se encontró un DocenteId válido en la sesión. Cierra sesión y vuelve a iniciar.";
            return;
        }

        var docente = await DocenteService.ObtenerPorIdAsync(currentDocenteId);
        if (docente == null)
        {
            canCreatePlan = false;
            sessionErrorMessage = $"El perfil docente asociado a tu sesión (ID {currentDocenteId}) ya no existe.";
        }
        else
        {
            canCreatePlan = true;
            sessionErrorMessage = string.Empty;
        }
    }

    private async Task LoadMetadata()
    {
        var curso = await CursoService.ObtenerPorIdAsync(CursoId);
        cursoNombre = curso?.Nombre ?? $"Curso #{CursoId}";
        
        secciones = (await SeccionService.ObtenerTodosAsync()).ToList();
        periodos = (await PeriodoService.ObtenerTodosAsync()).ToList();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            var todosPlanesDelCurso = await PlanificacionService.ObtenerPorCursoAsync(CursoId);
            
            // Si es docente, solo mostrar los suyos
            if (currentRole == "Docente" && currentDocenteId > 0)
            {
                planes = todosPlanesDelCurso.Where(p => p.DocenteId == currentDocenteId).ToList();
            }
            else
            {
                planes = todosPlanesDelCurso.ToList();
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ShowCreateForm()
    {
        if (!canCreatePlan)
        {
            errorMessage = string.IsNullOrWhiteSpace(sessionErrorMessage)
                ? "No puedes crear planificaciones hasta tener un perfil docente válido."
                : sessionErrorMessage;
            return;
        }

        editingPlan = new AcademicManager.Domain.Entities.Planificacion
        {
            CursoId = CursoId,
            DocenteId = currentDocenteId,
            AnoAcademico = DateTime.Now.Year,
            TipoplanificacionAcademico = "Anual",
            Estado = "Borrador",
            FechaClase = DateTime.Today
        };
        errorMessage = "";
        successMessage = "";
        showForm = true;
    }

    private void EditarPlan(AcademicManager.Domain.Entities.Planificacion plan)
    {
        editingPlan = new AcademicManager.Domain.Entities.Planificacion
        {
            Id = plan.Id,
            CursoId = plan.CursoId,
            DocenteId = plan.DocenteId,
            SeccionId = plan.SeccionId,
            PeriodoAcademicoId = plan.PeriodoAcademicoId,
            AnoAcademico = plan.AnoAcademico,
            Titulo = plan.Titulo,
            TipoplanificacionAcademico = plan.TipoplanificacionAcademico,
            Descripcion = plan.Descripcion,
            SituacionAprendizaje = plan.SituacionAprendizaje,
            CompetenciasFundamentales = plan.CompetenciasFundamentales,
            CompetenciasEspecificas = plan.CompetenciasEspecificas,
            ContenidosConceptuales = plan.ContenidosConceptuales,
            ContenidosProcedimentales = plan.ContenidosProcedimentales,
            ContenidosActitudinales = plan.ContenidosActitudinales,
            IndicadoresLogro = plan.IndicadoresLogro,
            EstrategiasEnsenanza = plan.EstrategiasEnsenanza,
            Recursos = plan.Recursos,
            EjesTransversales = plan.EjesTransversales,
            ActividadesEvaluacion = plan.ActividadesEvaluacion,
            Estado = plan.Estado,
            FechaClase = plan.FechaClase
        };
        errorMessage = "";
        successMessage = "";
        showForm = true;
    }

    private async Task GuardarPlan()
    {
        try
        {
            isSubmitting = true;
            errorMessage = "";
            successMessage = "";

            if (string.IsNullOrWhiteSpace(editingPlan.Titulo))
            {
                errorMessage = "El título es obligatorio.";
                return;
            }

            if (editingPlan.AnoAcademico < 2020)
            {
                errorMessage = "El año académico no es válido.";
                return;
            }

            if (editingPlan.Id == 0)
            {
                var (success, id, message) = await PlanificacionService.CrearAsync(editingPlan);
                if (success)
                {
                    successMessage = "✅ Plan anual creado exitosamente.";
                    showForm = false;
                    await LoadData();
                }
                else
                {
                    errorMessage = message;
                }
            }
            else
            {
                var (success, message) = await PlanificacionService.ActualizarAsync(editingPlan);
                if (success)
                {
                    successMessage = "✅ Plan anual actualizado.";
                    showForm = false;
                    await LoadData();
                }
                else
                {
                    errorMessage = message;
                }
            }
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task EliminarPlan(int id)
    {
        if (await JS.InvokeAsync<bool>("confirm", "¿Eliminar esta planificación anual? Se eliminarán también sus planes mensuales y diarios."))
        {
            var resultado = await PlanificacionService.EliminarAsync(id);
            if (resultado)
            {
                await LoadData();
            }
        }
    }

    private async Task AutocompletarConIA()
    {
        if (string.IsNullOrWhiteSpace(editingPlan.Titulo))
        {
            errorMessage = "⚠️ Escribe primero el título del plan para que la IA sepa de qué trata.";
            return;
        }

        isGeneratingAI = true;
        errorMessage = "";
        StateHasChanged();
        
        var dict = await AiService.SugerirPlanAnualAsync(editingPlan.Titulo, cursoNombre);
        
        if (dict.ContainsKey("Error"))
        {
            errorMessage = dict["Error"];
        }
        else
        {
            if (dict.TryGetValue("situacion_aprendizaje", out var valSit)) editingPlan.SituacionAprendizaje = valSit;
            if (dict.TryGetValue("competencias_fundamentales", out var valCf)) editingPlan.CompetenciasFundamentales = valCf;
            if (dict.TryGetValue("competencias_especificas", out var valCe)) editingPlan.CompetenciasEspecificas = valCe;
            if (dict.TryGetValue("conceptuales", out var valCon)) editingPlan.ContenidosConceptuales = valCon;
            if (dict.TryGetValue("procedimentales", out var valPro)) editingPlan.ContenidosProcedimentales = valPro;
            if (dict.TryGetValue("actitudinales", out var valAct)) editingPlan.ContenidosActitudinales = valAct;
            if (dict.TryGetValue("indicadores_logro", out var valInd)) editingPlan.IndicadoresLogro = valInd;
            if (dict.TryGetValue("estrategias", out var valEst)) editingPlan.EstrategiasEnsenanza = valEst;
            if (dict.TryGetValue("recursos", out var valRec)) editingPlan.Recursos = valRec;
            if (dict.TryGetValue("ejes", out var valEjes)) editingPlan.EjesTransversales = valEjes;
        }
        
        isGeneratingAI = false;
    }

    private void CancelarForm()
    {
        showForm = false;
        errorMessage = "";
    }

