@page "/planificador/cursos/{CursoId:int}/anual"
@using Radzen.Blazor
@inject AcademicManager.Application.Services.PlanificacionService PlanificacionService
@inject AcademicManager.Application.Services.CursoService CursoService
@inject AcademicManager.Application.Services.DocenteService DocenteService
@inject AcademicManager.Application.Services.PeriodoAcademicoService PeriodoService
@inject AcademicManager.Application.Services.SeccionService SeccionService
@inject AcademicManager.Application.Services.GradoService GradoService
@inject AcademicManager.Application.Services.AiService AiService
@inject AcademicManager.Application.Services.ExportService ExportService
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Planificación Anual | @cursoNombre</PageTitle>

<div class="plan-anual-page">
    <!-- BREADCRUMB -->
    <div class="plan-breadcrumb">
        <a href="/planificador" class="breadcrumb-link">📅 Mi Planificador</a>
        <span class="breadcrumb-sep">›</span>
        <span class="breadcrumb-current">📖 @cursoNombre</span>
        <span class="breadcrumb-sep">›</span>
        <span class="breadcrumb-active">Planificación Anual</span>
    </div>

    <!-- HEADER -->
    <div class="plan-header">
        <div class="plan-header-left">
            <div class="plan-level-badge anual-badge">NIVEL ANUAL</div>
            <h1 class="plan-title">Planificación Anual</h1>
            <p class="plan-subtitle">Curso: <strong>@cursoNombre</strong> · Año @DateTime.Now.Year</p>
        </div>
        <button class="btn btn-primary btn-crear" @onclick="ShowCreateForm" disabled="@(!canCreatePlan)">
            <span>+ Nueva Planificación Anual</span>
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(sessionErrorMessage))
    {
        <div class="alert alert-error">@sessionErrorMessage</div>
    }

    <!-- PLANES ANUALES LIST -->
    @if (isLoading)
    {
        <div class="plan-loading">
            <div class="spinner"></div>
            <span>Cargando planificaciones...</span>
        </div>
    }
    else if (!planes.Any() && !showForm)
    {
        <div class="plan-empty-state">
            <div class="empty-icon">📋</div>
            <div class="empty-title">No hay planificaciones anuales para este curso</div>
            <div class="empty-subtitle">Crea tu primer plan anual para comenzar</div>
            <button class="btn btn-primary mt-3" @onclick="ShowCreateForm">
                Crear Planificación Anual
            </button>
        </div>
    }
    else
    {
        <div class="planes-anuales-list">
            @foreach (var plan in planes)
            {
                <div class="plan-anual-card @(selectedPlanId == plan.Id ? "selected" : "")">
                    <div class="plan-card-header">
                        <div class="plan-card-icon">📋</div>
                        <div class="plan-card-info">
                            <h3 class="plan-card-title">@plan.Titulo</h3>
                            <p class="plan-card-meta">
                                Año @plan.AnoAcademico · @plan.Estado
                                @if (!string.IsNullOrEmpty(plan.Mes))
                                {
                                    <span> · @plan.Mes</span>
                                }
                            </p>
                        </div>
                        <div class="plan-card-status">
                            <span class="estado-badge estado-@plan.Estado.ToLower()">@plan.Estado</span>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(plan.SituacionAprendizaje))
                    {
                        <p class="plan-card-desc">@GetPlainTextPreview(plan.SituacionAprendizaje, 180)</p>
                    }

                    <div class="plan-card-actions">
                        <button class="btn btn-outline btn-sm" @onclick="() => VerMensuales(plan.Id)">
                            📅 Ver Planificación Mensual
                        </button>
                        <button class="btn btn-ghost btn-sm" @onclick="() => EditarPlan(plan)">
                            ✏️ Editar
                        </button>
                        @if (plan.Estado == "Borrador")
                        {
                            <button class="btn btn-ghost btn-sm text-danger" @onclick="() => EliminarPlan(plan.Id)" title="Eliminar">🗑️</button>
                        }
                        <button class="btn btn-ghost btn-sm" @onclick="() => DownloadPdf(plan)" title="Descargar PDF">📄 PDF</button>
                        <button class="btn btn-ghost btn-sm" @onclick="() => DownloadWord(plan)" title="Descargar Word">📝 DOCX</button>
                    </div>
                </div>
            }
        </div>
    }

    <!-- FORMULARIO CREAR/EDITAR -->
    @if (showForm)
    {
        <div class="plan-form-container">
            <div class="plan-form-header">
                <h2 class="plan-form-title">
                    @(editingPlan.Id == 0 ? "✨ Nueva Planificación Anual" : "✏️ Editar Planificación Anual")
                </h2>
                <button class="btn btn-ghost btn-icon" @onclick="CancelarForm">✕</button>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-error">@errorMessage</div>
            }
            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="alert alert-success">@successMessage</div>
            }

            <div class="form-sections">
                <!-- SECCIÓN 1: IDENTIFICACIÓN -->
                <div class="form-section">
                    <div class="form-section-title" style="border-color: #667eea; color: #667eea;">
                        📋 Identificación
                    </div>
                    <div class="form-grid-2">
                        <div class="form-group">
                            <label class="form-label">Título / Nombre del Plan <span class="required">*</span></label>
                            <input type="text" class="form-control" @bind="editingPlan.Titulo"
                                   placeholder="Ej: Plan Anual de Matemáticas 2025" />
                            <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 0.35rem;">
                                <small class="form-hint" style="margin-top: 0;"></small>
                                <button type="button" class="btn btn-outline btn-sm" @onclick="AutocompletarConIA" disabled="@isGeneratingAI" style="margin-bottom: 0; padding: 0.2rem 0.5rem; font-size: 0.8rem; height: auto;">
                                    @(isGeneratingAI ? "✨ Generando..." : "✨ Planificar por mí (IA)")
                                </button>
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Año Académico <span class="required">*</span></label>
                            <input type="number" class="form-control" @bind="editingPlan.AnoAcademico"
                                   min="2020" max="2035" placeholder="@DateTime.Now.Year" />
                        </div>
                    </div>
                    <div class="form-grid-2">
                        <div class="form-group">
                            <label class="form-label">Sección</label>
                            <select class="form-control" @bind="editingPlan.SeccionId">
                                <option value="0">-- Seleccione --</option>
                                @foreach (var s in secciones)
                                {
                                    <option value="@s.Id">Sección @s.Nombre</option>
                                }
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Período Académico</label>
                            <select class="form-control" @bind="editingPlan.PeriodoAcademicoId">
                                <option value="0">-- Seleccione --</option>
                                @foreach (var p in periodos)
                                {
                                    <option value="@p.Id">@p.Nombre</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Descripción General</label>
                        <RadzenHtmlEditor @bind-Value="editingPlan.Descripcion" class="rich-text-editor" Style="height: 170px;" />
                    </div>
                </div>

                <!-- SECCIÓN 2: SITUACIÓN DE APRENDIZAJE -->
                <div class="form-section">
                    <div class="form-section-title" style="border-color: #11998e; color: #11998e;">
                        🎯 Situación de Aprendizaje (MINERD)
                    </div>
                    <div class="form-group">
                        <label class="form-label">Situación de Aprendizaje <span class="required">*</span></label>
                        <RadzenHtmlEditor @bind-Value="editingPlan.SituacionAprendizaje" class="rich-text-editor" Style="height: 240px;" />
                        <small class="form-hint">💡 MINERD: Problema real del entorno que da sentido al aprendizaje</small>
                    </div>
                </div>

                <!-- SECCIÓN 3: COMPETENCIAS -->
                <div class="form-section">
                    <div class="form-section-title" style="border-color: #f5576c; color: #f5576c;">
                        🏆 Competencias (MINERD)
                    </div>
                    <div class="form-group">
                        <label class="form-label">Competencias Fundamentales <span class="required">*</span></label>
                        <RadzenHtmlEditor @bind-Value="editingPlan.CompetenciasFundamentales" class="rich-text-editor" Style="height: 220px;" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Competencias Específicas del Área <span class="required">*</span></label>
                        <RadzenHtmlEditor @bind-Value="editingPlan.CompetenciasEspecificas" class="rich-text-editor" Style="height: 220px;" />
                    </div>
                </div>

                <!-- SECCIÓN 4: CONTENIDOS -->
                <div class="form-section">
                    <div class="form-section-title" style="border-color: #4facfe; color: #4facfe;">
                        📚 Contenidos Anuales (Triangulación MINERD)
                    </div>
                    <div class="form-group">
                        <label class="form-label">Contenidos Conceptuales <span class="required">*</span></label>
                        <RadzenHtmlEditor @bind-Value="editingPlan.ContenidosConceptuales" class="rich-text-editor" Style="height: 220px;" />
                        <small class="form-hint">👉 Saber Qué (declarativo)</small>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Contenidos Procedimentales <span class="required">*</span></label>
                        <RadzenHtmlEditor @bind-Value="editingPlan.ContenidosProcedimentales" class="rich-text-editor" Style="height: 220px;" />
                        <small class="form-hint">👉 Saber Hacer (procedimental)</small>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Contenidos Actitudinales <span class="required">*</span></label>
                        <RadzenHtmlEditor @bind-Value="editingPlan.ContenidosActitudinales" class="rich-text-editor" Style="height: 220px;" />
                        <small class="form-hint">👉 Saber Ser (actitudinal)</small>
                    </div>
                </div>

                <!-- SECCIÓN 5: INDICADORES Y EVALUACIÓN -->
                <div class="form-section">
                    <div class="form-section-title" style="border-color: #a18cd1; color: #8e44ad;">
                        ✅ Indicadores y Evaluación
                    </div>
                    <div class="form-group">
                        <label class="form-label">Indicadores de Logro <span class="required">*</span></label>
                        <RadzenHtmlEditor @bind-Value="editingPlan.IndicadoresLogro" class="rich-text-editor" Style="height: 240px;" />
                        <small class="form-hint">💡 Use verbos observables: demuestra, identifica, construye, analiza, evalúa</small>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Estrategias de Enseñanza</label>
                        <RadzenHtmlEditor @bind-Value="editingPlan.EstrategiasEnsenanza" class="rich-text-editor" Style="height: 220px;" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Recursos Didácticos</label>
                        <input type="text" class="form-control" @bind="editingPlan.Recursos"
                               placeholder="Ej: Libros de texto, pizarra, TIC, material manipulativo..." />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Ejes Transversales</label>
                        <RadzenHtmlEditor @bind-Value="editingPlan.EjesTransversales" class="rich-text-editor" Style="height: 170px;" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Actividades de Evaluación</label>
                        <RadzenHtmlEditor @bind-Value="editingPlan.ActividadesEvaluacion" class="rich-text-editor" Style="height: 220px;" />
                    </div>
                </div>
            </div>

            <div class="form-actions">
                <button class="btn btn-secondary" @onclick="CancelarForm" disabled="@isSubmitting">
                    Cancelar
                </button>
                <button class="btn btn-primary" @onclick="GuardarPlan" disabled="@isSubmitting">
                    @if (isSubmitting)
                    {
                        <span>Guardando...</span>
                    }
                    else
                    {
                        <span>💾 Guardar Plan Anual</span>
                    }
                </button>
            </div>
        </div>
    }
</div>

<style>
.plan-anual-page { display: flex; flex-direction: column; gap: 1.25rem; }

.plan-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-muted);
}

.breadcrumb-link {
    color: #667eea;
    text-decoration: none;
    font-weight: 500;
}
.breadcrumb-link:hover { text-decoration: underline; }
.breadcrumb-sep { color: var(--border); }
.breadcrumb-active { color: var(--text-primary); font-weight: 600; }

.plan-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.5rem;
}

.plan-level-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    letter-spacing: 0.5px;
    margin-bottom: 0.5rem;
}

.anual-badge {
    background: linear-gradient(135deg, #667eea, #764ba2);
    color: white;
}

.plan-title {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text-primary);
    margin: 0 0 0.25rem 0;
}

.plan-subtitle {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin: 0;
}

.planes-anuales-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.plan-anual-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.5rem;
    transition: all 0.2s;
}

.plan-anual-card:hover {
    border-color: #667eea;
    box-shadow: 0 4px 16px rgba(102,126,234,0.1);
}

.plan-anual-card.selected {
    border-color: #667eea;
    background: rgba(102,126,234,0.03);
}

.plan-card-header {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 0.75rem;
}

.plan-card-icon { font-size: 1.75rem; flex-shrink: 0; }

.plan-card-info { flex: 1; }

.plan-card-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 0.2rem 0;
}

.plan-card-meta {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin: 0;
}

.plan-card-desc {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin: 0 0 1rem 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.plan-card-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
}

.plan-loading {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 3rem;
    color: var(--text-muted);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
}

.plan-empty-state {
    text-align: center;
    padding: 4rem 2rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
}

.plan-form-container {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem;
}

.plan-form-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
}

.plan-form-title {
    font-size: 1.25rem;
