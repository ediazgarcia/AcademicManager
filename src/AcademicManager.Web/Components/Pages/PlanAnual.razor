    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.form-grid-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1rem;
}

.form-group { margin-bottom: 1rem; }
.form-group:last-child { margin-bottom: 0; }

.form-label {
    display: block;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text-secondary);
    margin-bottom: 0.35rem;
}

.required { color: #ef4444; }

.form-hint {
    display: block;
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 0.35rem;
}

.form-actions {
    display: flex;
    justify-content: flex-end;
    gap: 0.75rem;
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
}

.estado-badge { font-size: 0.72rem; font-weight: 600; padding: 0.25rem 0.6rem; border-radius: 20px; }
.estado-borrador { background: rgba(245,158,11,0.1); color: #d97706; }
.estado-aprobado { background: rgba(16,185,129,0.1); color: #059669; }
.estado-enviado { background: rgba(59,130,246,0.1); color: #2563eb; }

.btn-outline {
    background: transparent;
    border: 1px solid #667eea;
    color: #667eea;
    font-weight: 600;
}
.btn-outline:hover {
    background: rgba(102,126,234,0.1);
}

.rich-text-editor {
    border: 1px solid var(--border);
