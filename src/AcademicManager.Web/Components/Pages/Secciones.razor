@page "/secciones"
@inject AcademicManager.Application.Services.SeccionService SeccionService
@inject AcademicManager.Application.Services.GradoService GradoService
@inject IJSRuntime JS
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Secciones | AcademicManager</PageTitle>

<div class="data-card">
    <div class="data-card-header">
        <div class="d-flex align-center gap-2">
            <h2>📋 Gestión de Secciones</h2>
            <span class="badge badge-primary">@TotalItems Total</span>
        </div>
        <div class="data-card-actions">
            <div class="search-box">
                <input type="text" placeholder="Buscar por nombre..." 
                       @bind="searchTerm" @bind:event="oninput" @onkeyup="OnSearchChanged" />
            </div>
            <button class="btn btn-primary" @onclick="ShowCreateModal">
                <span>+ Nueva Sección</span>
            </button>
        </div>
    </div>
    
    <div class="p-3 bg-surface-hover border-bottom">
        <div class="form-group" style="max-width: 300px; margin-bottom: 0;">
            <label>Filtrar por Grado:</label>
            <select class="form-control" @onchange="FilterByGrado">
                <option value="0">-- Todos los Grados --</option>
                @foreach (var g in grados)
                {
                    <option value="@g.Id">@g.Nombre (@g.Nivel)</option>
                }
            </select>
        </div>
    </div>

    <div class="table-responsive">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Grado / Nivel</th>
                    <th>Capacidad</th>
                    <th>Estado</th>
                    <th class="text-right">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (isLoading)
                {
                    <tr><td colspan="5" class="text-center p-3">
                        <div class="spinner"></div>
                    </td></tr>
                }
                else if (!PaginatedSecciones.Any())
                {
                    <tr><td colspan="5">
                        <div class="empty-state">
                            <div class="empty-state-icon">📋</div>
                            <div class="empty-state-text">No se encontraron secciones</div>
                            <div class="empty-state-subtext">
                                @if (!string.IsNullOrWhiteSpace(searchTerm) || filterGradoId > 0)
                                {
                                    <span>Intenta con otro criterio de búsqueda</span>
                                }
                                else
                                {
                                    <span>Comienza agregando tu primera sección</span>
                                }
                            </div>
                        </div>
                    </td></tr>
                }
                else
                {
                    @foreach (var s in PaginatedSecciones)
                    {
                        <tr>
                            <td class="fw-bold">Sección "@s.Nombre"</td>
                            <td>
                                @if (s.Grado != null)
                                {
                                    <span>@s.Grado.Nombre <span class="text-muted small">(@s.Grado.Nivel)</span></span>
                                }
                                else
                                {
                                    <span class="text-muted">--</span>
                                }
                            </td>
                            <td>@s.Capacidad alumnos</td>
                            <td>
                                @if (s.Activo)
                                {
                                    <span class="badge badge-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge badge-secondary">Inactivo</span>
                                }
                            </td>
                            <td class="text-right">
                                <button class="btn btn-ghost btn-sm" @onclick="() => Edit(s)" title="Editar">✏️</button>
                                <button class="btn btn-ghost btn-sm text-danger" @onclick="() => Delete(s.Id)" title="Eliminar">🗑️</button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
    
    @if (TotalItems > 0)
    {
        <Pagination CurrentPage="@currentPage" 
                    PageSize="@pageSize" 
                    TotalItems="@TotalItems"
                    OnPageChanged="HandlePageChanged"
                    OnPageSizeChanged="HandlePageSizeChanged" />
    }
</div>

@if (showModal)
{
    <div class="modal-overlay" @onclick="@(() => { if (!isSubmitting) CloseModal(); })">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>@(editingSeccion.Id == 0 ? "Nueva Sección" : "Editar Sección")</h3>
                <button class="btn btn-ghost btn-icon" @onclick="CloseModal" disabled="@isSubmitting">✕</button>
            </div>
            
            <EditForm Model="editingSeccion" OnValidSubmit="Save" FormName="SeccionForm">
                <DataAnnotationsValidator />
                
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-error">@errorMessage</div>
                    }
                    
                    <div class="form-group">
                        <label>Grado al que pertenece <span class="text-danger">*</span></label>
                        <InputSelect class="form-control" @bind-Value="editingSeccion.GradoId">
                            <option value="0">-- Seleccione Grado --</option>
                            @foreach (var g in grados)
                            {
                                <option value="@g.Id">@g.Nombre - @g.Nivel</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="@(() => editingSeccion.GradoId)" />
                    </div>

                    <div class="form-grid">
                        <div class="form-group">
                            <label>Nombre de Sección <span class="text-danger">*</span></label>
                            <InputText class="form-control" @bind-Value="editingSeccion.Nombre" placeholder="Ej: A, B, C, Única" />
                            <ValidationMessage For="@(() => editingSeccion.Nombre)" />
                        </div>
                        <div class="form-group">
                            <label>Capacidad Máxima</label>
                            <InputNumber class="form-control" @bind-Value="editingSeccion.Capacidad" />
                        </div>
                    </div>

                    <div class="form-group mt-3">
                        <label class="d-flex align-center gap-1">
                            <InputCheckbox @bind-Value="editingSeccion.Activo" />
                            <span>Sección Activa</span>
                        </label>
                    </div>
                </div>
                
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal" disabled="@isSubmitting">Cancelar</button>
                    <button type="submit" class="btn btn-primary" disabled="@(isSubmitting || editingSeccion.GradoId == 0)">
                        @if (isSubmitting)
                        {
                            <span>Guardando...</span>
                        }
                        else
                        {
                            <span>Guardar</span>
                        }
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    private List<AcademicManager.Domain.Entities.Seccion> allSecciones = new();
    private List<AcademicManager.Domain.Entities.Grado> grados = new();
    private AcademicManager.Domain.Entities.Seccion editingSeccion = new();
    
    private bool showModal = false;
    private bool isLoading = true;
    private bool isSubmitting = false;
    private string searchTerm = "";
    private string errorMessage = "";
    private int filterGradoId = 0;
    
    // Paginación
    private int currentPage = 1;
    private int pageSize = 10;
    
    private IEnumerable<AcademicManager.Domain.Entities.Seccion> FilteredSecciones
    {
        get
        {
            var filtered = allSecciones.AsEnumerable();
            
            // Filtro por grado
            if (filterGradoId > 0)
            {
                filtered = filtered.Where(s => s.GradoId == filterGradoId);
            }
            
            // Filtro por búsqueda
            if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                filtered = filtered.Where(s => 
                    (s.Nombre?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false));
            }
            
            return filtered;
        }
    }
    
    private int TotalItems => FilteredSecciones.Count();
    
    private IEnumerable<AcademicManager.Domain.Entities.Seccion> PaginatedSecciones =>
        FilteredSecciones
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize);

    protected override async Task OnInitializedAsync()
    {
        await LoadMetadata();
        await LoadData();
    }

    private async Task LoadMetadata()
    {
        grados = (await GradoService.ObtenerTodosAsync()).ToList();
    }

    private async Task LoadData()
    {
        isLoading = true;
        
        if (filterGradoId > 0)
        {
            allSecciones = (await SeccionService.ObtenerPorGradoAsync(filterGradoId)).ToList();
            foreach(var s in allSecciones)
            {
                s.Grado = grados.FirstOrDefault(g => g.Id == s.GradoId);
            }
        }
        else
        {
            allSecciones = (await SeccionService.ObtenerTodosAsync()).ToList();
        }
        
        isLoading = false;
    }
    
    private void OnSearchChanged()
    {
        currentPage = 1;
    }
    
    private async Task FilterByGrado(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
        {
            filterGradoId = id;
            currentPage = 1;
            await LoadData();
        }
    }
    
    private async Task HandlePageChanged(int newPage)
    {
        currentPage = newPage;
        await Task.CompletedTask;
    }
    
    private async Task HandlePageSizeChanged(int newSize)
    {
        pageSize = newSize;
        currentPage = 1;
        await Task.CompletedTask;
    }

    private void ShowCreateModal()
    {
        editingSeccion = new AcademicManager.Domain.Entities.Seccion 
        { 
            Capacidad = 30,
            Activo = true
        };
        errorMessage = "";
        showModal = true;
    }

    private void Edit(AcademicManager.Domain.Entities.Seccion item)
    {
        editingSeccion = new AcademicManager.Domain.Entities.Seccion
        {
            Id = item.Id,
            Nombre = item.Nombre,
            GradoId = item.GradoId,
            Capacidad = item.Capacidad,
            Activo = item.Activo
        };
        errorMessage = "";
        showModal = true;
    }

    private void CloseModal()
    {
        if (!isSubmitting)
        {
            showModal = false;
            errorMessage = "";
        }
    }

    private async Task Save()
    {
        try
        {
            isSubmitting = true;
            errorMessage = "";
            
            if (editingSeccion.Id == 0)
            {
                await SeccionService.CrearAsync(editingSeccion);
            }
            else
            {
                await SeccionService.ActualizarAsync(editingSeccion);
            }
            
            showModal = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al guardar: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task Delete(int id)
    {
        if (await JS.InvokeAsync<bool>("confirm", "⚠️ ¿Estás seguro de eliminar esta sección? Esta acción no se puede deshacer."))
        {
            try
            {
                await SeccionService.EliminarAsync(id);
                await LoadData();
                
                var totalPages = (int)Math.Ceiling((double)TotalItems / pageSize);
                if (currentPage > totalPages && totalPages > 0)
                {
                    currentPage = totalPages;
                }
            }
            catch (Exception ex)
            {
                await JS.InvokeVoidAsync("alert", $"Error al eliminar: {ex.Message}");
            }
        }
    }
}
