@code {
    [Parameter] public int PlanAnualId { get; set; }

    private AcademicManager.Domain.Entities.Planificacion? planAnual;
    private List<AcademicManager.Domain.Entities.PlanificacionMensual> planesMensuales = new();
    private List<(int NumeroMes, string NombreMes, AcademicManager.Domain.Entities.PlanificacionMensual? Plan)> progresoMeses = new();
    private AcademicManager.Domain.Entities.PlanificacionMensual editingPlan = new();

    private bool isLoading = true;
    private bool showForm = false;
    private bool isSubmitting = false;
    private bool isGeneratingAI = false;
    private string errorMessage = "";
    private int selectedMes = 0;
    private int mesesCompletados = 0;
    private int currentDocenteId = 0;
    private string currentRole = "";
    private bool canCreateMensual = true;
    private string sessionErrorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        var session = HttpContextAccessor.HttpContext?.Session;
        currentRole = session?.GetString("UserRole") ?? "";
        currentDocenteId = session?.GetInt32("DocenteId") ?? 0;

        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            // Cargar plan anual padre
            planAnual = await PlanificacionService.ObtenerPorIdAsync(PlanAnualId);
            if (planAnual == null)
            {
                canCreateMensual = false;
                sessionErrorMessage = "No se encontró la planificación anual asociada.";
                return;
            }

            var docente = await DocenteService.ObtenerPorIdAsync(planAnual.DocenteId);
            if (docente == null)
            {
                canCreateMensual = false;
                sessionErrorMessage = $"La planificación anual está asociada a un docente inexistente (ID {planAnual.DocenteId}).";
            }
            else
            {
                canCreateMensual = true;
                sessionErrorMessage = string.Empty;
            }

            // Cargar planes mensuales
            planesMensuales = (await MensualService.ObtenerPorPlanAnualAsync(PlanAnualId)).ToList();
            mesesCompletados = planesMensuales.Count;

            // Calcular progreso mes a mes
            progresoMeses = await MensualService.ObtenerProgresoMensualAsync(PlanAnualId);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void SeleccionarMes(int numMes, string nombreMes, AcademicManager.Domain.Entities.PlanificacionMensual? planExistente)
    {
        if (planExistente != null)
        {
            // Si ya tiene plan, editar
            selectedMes = numMes;
            EditarMensual(planExistente);
        }
        else
        {
            // Si no tiene plan, crear nuevo
            selectedMes = numMes;
            IniciarCrearMes(numMes, nombreMes);
        }
    }

    private void IniciarCrearMes(int numMes, string nombreMes)
    {
        editingPlan = new AcademicManager.Domain.Entities.PlanificacionMensual
        {
            PlanificacionId = PlanAnualId,
            DocenteId = planAnual?.DocenteId ?? currentDocenteId,
            CursoId = planAnual?.CursoId ?? 0,
            SeccionId = planAnual?.SeccionId ?? 0,
            PeriodoAcademicoId = planAnual?.PeriodoAcademicoId ?? 0,
            NumeroMes = numMes,
            Mes = nombreMes,
            Estado = "Borrador",
            // Pre-llenar desde el plan anual para facilitar
            CompetenciasFundamentales = planAnual?.CompetenciasFundamentales ?? "",
            CompetenciasEspecificas = planAnual?.CompetenciasEspecificas ?? ""
        };
        errorMessage = "";
        showForm = true;
    }

    private void ShowCreateForm()
    {
        if (!canCreateMensual)
        {
            errorMessage = string.IsNullOrWhiteSpace(sessionErrorMessage)
                ? "No puedes crear planes mensuales hasta corregir el docente asociado."
                : sessionErrorMessage;
            return;
        }

        // Por defecto, abrir con el primer mes no planificado
        var primerMesSinPlan = progresoMeses.FirstOrDefault(m => m.Plan == null);
        if (primerMesSinPlan != default)
        {
            IniciarCrearMes(primerMesSinPlan.NumeroMes, primerMesSinPlan.NombreMes);
        }
        else
        {
            IniciarCrearMes(8, "Agosto"); // Fallback
        }
    }

    private void EditarMensual(AcademicManager.Domain.Entities.PlanificacionMensual pm)
    {
        editingPlan = new AcademicManager.Domain.Entities.PlanificacionMensual
        {
            Id = pm.Id,
            PlanificacionId = pm.PlanificacionId,
            DocenteId = pm.DocenteId,
            CursoId = pm.CursoId,
            SeccionId = pm.SeccionId,
            PeriodoAcademicoId = pm.PeriodoAcademicoId,
            NumeroMes = pm.NumeroMes,
            Mes = pm.Mes,
            TituloUnidad = pm.TituloUnidad,
            SituacionAprendizaje = pm.SituacionAprendizaje,
            CompetenciasFundamentales = pm.CompetenciasFundamentales,
            CompetenciasEspecificas = pm.CompetenciasEspecificas,
            ContenidosConceptuales = pm.ContenidosConceptuales,
            ContenidosProcedimentales = pm.ContenidosProcedimentales,
            ContenidosActitudinales = pm.ContenidosActitudinales,
            IndicadoresLogro = pm.IndicadoresLogro,
            EstrategiasEnsenanza = pm.EstrategiasEnsenanza,
            RecursosDidacticos = pm.RecursosDidacticos,
            ActividadesEvaluacion = pm.ActividadesEvaluacion,
            EjesTransversales = pm.EjesTransversales,
            Observaciones = pm.Observaciones,
            Estado = pm.Estado
        };
        errorMessage = "";
        showForm = true;
    }

    private void OnMesChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int numMes))
        {
            editingPlan.NumeroMes = numMes;
            var mesInfo = AcademicManager.Application.Services.PlanificacionMensualService.MesesLectivos.FirstOrDefault(m => m.Numero == numMes);
            editingPlan.Mes = mesInfo.Nombre ?? $"Mes {numMes}";
        }
    }

    private async Task GuardarMensual()
    {
        try
        {
            isSubmitting = true;
            errorMessage = "";

            if (!canCreateMensual)
            {
                errorMessage = string.IsNullOrWhiteSpace(sessionErrorMessage)
                    ? "No puedes guardar esta planificación mensual por un problema con el docente asociado."
                    : sessionErrorMessage;
                return;
            }

            if (string.IsNullOrWhiteSpace(editingPlan.TituloUnidad))
            {
                errorMessage = "El título de la unidad es obligatorio.";
                return;
            }

            if (editingPlan.Id == 0)
            {
                var (success, id, message) = await MensualService.CrearAsync(editingPlan);
                if (success)
                {
                    showForm = false;
                    selectedMes = 0;
                    await LoadData();
                }
                else
                {
                    errorMessage = message;
                }
            }
            else
            {
                var (success, message) = await MensualService.ActualizarAsync(editingPlan);
                if (success)
                {
                    showForm = false;
                    selectedMes = 0;
                    await LoadData();
                }
                else
                {
                    errorMessage = message;
                }
            }
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task EliminarMensual(int id)
    {
        if (await JS.InvokeAsync<bool>("confirm", "¿Eliminar este plan mensual?"))
        {
            var (success, message) = await MensualService.EliminarAsync(id);
            if (success) await LoadData();
        }
    }

    private async Task AutocompletarConIA()
    {
        if (string.IsNullOrWhiteSpace(editingPlan.TituloUnidad))
        {
            errorMessage = "⚠️ Escribe primero el Título de la Unidad para que la IA sepa de qué trata.";
            return;
        }

        isGeneratingAI = true;
        errorMessage = "";
        StateHasChanged();
        
        string temaAnual = planAnual?.Titulo ?? "Plan Anual del Curso";
        var dict = await AiService.SugerirPlanMensualAsync(editingPlan.TituloUnidad, temaAnual);
        
        if (dict.ContainsKey("Error"))
        {
            errorMessage = dict["Error"];
        }
        else
        {
            if (dict.TryGetValue("situacion_aprendizaje", out var valSit)) editingPlan.SituacionAprendizaje = valSit;
            if (dict.TryGetValue("competencias_fundamentales", out var valCf)) editingPlan.CompetenciasFundamentales = valCf;
            if (dict.TryGetValue("competencias_especificas", out var valCe)) editingPlan.CompetenciasEspecificas = valCe;
            if (dict.TryGetValue("conceptuales", out var valCon)) editingPlan.ContenidosConceptuales = valCon;
            if (dict.TryGetValue("procedimentales", out var valPro)) editingPlan.ContenidosProcedimentales = valPro;
            if (dict.TryGetValue("actitudinales", out var valAct)) editingPlan.ContenidosActitudinales = valAct;
            if (dict.TryGetValue("indicadores_logro", out var valInd)) editingPlan.IndicadoresLogro = valInd;
            if (dict.TryGetValue("estrategias", out var valEst)) editingPlan.EstrategiasEnsenanza = valEst;
            if (dict.TryGetValue("recursos", out var valRec)) editingPlan.RecursosDidacticos = valRec;
            if (dict.TryGetValue("ejes", out var valEjes)) editingPlan.EjesTransversales = valEjes;
        }
        
        isGeneratingAI = false;
    }

    private void CancelarForm()
    {
        showForm = false;
        selectedMes = 0;
        errorMessage = "";
    }

