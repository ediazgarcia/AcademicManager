        var bytes = ExportService.GenerarWordPlanMensual(plan);
        await JS.InvokeVoidAsync("downloadFileFromBase64", $"PlanMensual_{plan.Mes}.docx", Convert.ToBase64String(bytes));
    }

    private static string GetPlainTextPreview(string? html, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(html))
        {
            return string.Empty;
        }

        var withoutTags = System.Text.RegularExpressions.Regex.Replace(html, "<.*?>", " ");
        var normalized = System.Text.RegularExpressions.Regex.Replace(System.Net.WebUtility.HtmlDecode(withoutTags), @"\s+", " ").Trim();
        if (normalized.Length <= maxLength)
        {
            return normalized;
        }

        return $"{normalized[..maxLength]}...";
    }

