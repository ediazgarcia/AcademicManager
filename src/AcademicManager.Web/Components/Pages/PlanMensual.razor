@page "/planificador/anual/{PlanAnualId:int}/mensual"
@using Radzen.Blazor
@inject AcademicManager.Application.Services.PlanificacionService PlanificacionService
@inject AcademicManager.Application.Services.PlanificacionMensualService MensualService
@inject AcademicManager.Application.Services.DocenteService DocenteService
@inject AcademicManager.Application.Services.CursoService CursoService
@inject AcademicManager.Application.Services.AiService AiService
@inject AcademicManager.Application.Services.ExportService ExportService
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Planificación Mensual | AcademicManager</PageTitle>

<div class="plan-mensual-page">
    <!-- BREADCRUMB -->
    <div class="plan-breadcrumb">
        <a href="/planificador" class="breadcrumb-link">📅 Mi Planificador</a>
        <span class="breadcrumb-sep">›</span>
        @if (planAnual != null)
        {
            <a href="/planificador/cursos/@planAnual.CursoId/anual" class="breadcrumb-link">📖 @(planAnual.Curso?.Nombre ?? "Curso")</a>
            <span class="breadcrumb-sep">›</span>
        }
        <span class="breadcrumb-active">Planificación Mensual</span>
    </div>

    <!-- PLAN ANUAL INFO -->
    @if (planAnual != null)
    {
        <div class="plan-parent-info">
            <div class="plan-parent-badge anual-badge">PLAN ANUAL</div>
            <div class="plan-parent-content">
                <h2 class="plan-parent-title">@planAnual.Titulo</h2>
                <p class="plan-parent-meta">
                    Año @planAnual.AnoAcademico · @(planAnual.Curso?.Nombre ?? "") · 
                    <span class="estado-badge estado-@planAnual.Estado.ToLower()">@planAnual.Estado</span>
                </p>
            </div>
        </div>
    }

    <!-- HEADER -->
    <div class="plan-header">
        <div>
            <div class="plan-level-badge mensual-badge">NIVEL MENSUAL</div>
            <h1 class="plan-title">Planificaciones Mensuales</h1>
            <p class="plan-subtitle">@mesesCompletados de 11 meses planificados</p>
        </div>
        <button class="btn btn-primary" @onclick="ShowCreateForm" disabled="@(showForm || !canCreateMensual)">
            + Nueva Planificación Mensual
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(sessionErrorMessage))
    {
        <div class="alert alert-error">@sessionErrorMessage</div>
    }

    <!-- OVERVIEW MESES - CALENDARIO VISUAL -->
    <div class="meses-overview">
        @foreach (var (numMes, nombreMes, plan) in progresoMeses)
        {
            <div class="mes-chip @(plan != null ? "mes-con-plan" : "mes-sin-plan") @(selectedMes == numMes ? "mes-selected" : "")"
                 @onclick="() => SeleccionarMes(numMes, nombreMes, plan)">
                <div class="mes-chip-nombre">@nombreMes</div>
                @if (plan != null)
                {
                    <div class="mes-chip-status">✓</div>
                }
                else
                {
                    <div class="mes-chip-status plus">+</div>
                }
            </div>
        }
    </div>

    <!-- LOADING -->
    @if (isLoading)
    {
        <div class="plan-loading">
            <div class="spinner"></div>
            <span>Cargando planificaciones mensuales...</span>
        </div>
    }

    <!-- PLANES MENSUALES EXISTENTES -->
    @if (!isLoading && planesMensuales.Any() && !showForm)
    {
        <div class="planes-list">
            @foreach (var pm in planesMensuales.OrderBy(p => p.NumeroMes))
            {
                <div class="plan-mensual-card">
                    <div class="plan-card-header">
                        <div class="mes-indicator">
                            <span class="mes-num">@pm.NumeroMes</span>
                        </div>
                        <div class="plan-card-info">
                            <h3 class="plan-card-title">@pm.Mes — @pm.TituloUnidad</h3>
                            <p class="plan-card-meta">
                                Estado: <span class="estado-badge estado-@pm.Estado.ToLower()">@pm.Estado</span>
                            </p>
                        </div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(pm.SituacionAprendizaje))
                    {
                        <p class="plan-card-desc">@GetPlainTextPreview(pm.SituacionAprendizaje, 180)</p>
                    }
                    <div class="plan-card-actions">
                        <button class="btn btn-outline btn-sm" @onclick="() => VerDiarios(pm.Id)">
                            📆 Ver Planes Diarios
                        </button>
                        <button class="btn btn-ghost btn-sm" @onclick="() => EditarMensual(pm)">
                            ✏️ Editar
                        </button>
                        @if (pm.Estado == "Borrador")
                        {
                            <button class="btn btn-ghost btn-sm text-danger" @onclick="() => EliminarMensual(pm.Id)" title="Eliminar">🗑️</button>
                        }
                        <button class="btn btn-ghost btn-sm" @onclick="() => DownloadPdf(pm)" title="Descargar PDF">📄 PDF</button>
                        <button class="btn btn-ghost btn-sm" @onclick="() => DownloadWord(pm)" title="Descargar Word">📝 DOCX</button>
                    </div>
                </div>
            }
        </div>
    }

    <!-- FORMULARIO CREAR/EDITAR MENSUAL -->
    @if (showForm)
    {
        <div class="plan-form-container">
            <div class="plan-form-header">
                <h2 class="plan-form-title">
                    @(editingPlan.Id == 0 ? $"✨ Plan Mensual — {editingPlan.Mes}" : $"✏️ Editar Plan — {editingPlan.Mes}")
                </h2>
                <button class="btn btn-ghost btn-icon" @onclick="CancelarForm">✕</button>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-error">@errorMessage</div>
            }

            <div class="form-sections">
                <!-- SECCIÓN 1: MES Y UNIDAD -->
                <div class="form-section">
                    <div class="form-section-title" style="border-color: #11998e; color: #11998e;">
                        📅 Identificación del Mes
                    </div>
                    <div class="form-grid-2">
                        <div class="form-group">
                            <label class="form-label">Mes <span class="required">*</span></label>
                            <select class="form-control" value="@editingPlan.NumeroMes"
                                    @onchange="OnMesChanged" disabled="@(editingPlan.Id > 0)">
                                @foreach (var (num, nombre) in AcademicManager.Application.Services.PlanificacionMensualService.MesesLectivos)
                                {
                                    <option value="@num">@nombre</option>
                                }
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Estado</label>
                            <select class="form-control" @bind="editingPlan.Estado">
                                <option value="Borrador">Borrador</option>
                                <option value="Aprobado">Aprobado</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Título de la Unidad <span class="required">*</span></label>
                        <input type="text" class="form-control" @bind="editingPlan.TituloUnidad"
                               placeholder="Ej: Unidad 2 — Los Números Decimales" />
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 0.35rem;">
                            <small class="form-hint" style="margin-top: 0;"></small>
                            <button type="button" class="btn btn-outline btn-sm" @onclick="AutocompletarConIA" disabled="@isGeneratingAI" style="margin-bottom: 0; padding: 0.2rem 0.5rem; font-size: 0.8rem; height: auto;">
                                @(isGeneratingAI ? "✨ Generando..." : "✨ Planificar por mí (IA)")
                            </button>
                        </div>
                    </div>
                </div>

                <!-- SECCIÓN 2: SITUACIÓN DE APRENDIZAJE -->
                <div class="form-section">
                    <div class="form-section-title" style="border-color: #667eea; color: #667eea;">
                        🎯 Situación de Aprendizaje
                    </div>
                    <div class="form-group">
                        <label class="form-label">Situación de Aprendizaje <span class="required">*</span></label>
                        <RadzenHtmlEditor @bind-Value="editingPlan.SituacionAprendizaje" class="rich-text-editor" Style="height: 240px;" />
                        <small class="form-hint">💡 MINERD: Contexto auténtico del entorno del estudiante para este mes</small>
                    </div>
                </div>

                <!-- SECCIÓN 3: COMPETENCIAS -->
                <div class="form-section">
                    <div class="form-section-title" style="border-color: #f5576c; color: #f5576c;">
                        🏆 Competencias del Mes
                    </div>
                    <div class="form-group">
                        <label class="form-label">Competencias Fundamentales</label>
                        <RadzenHtmlEditor @bind-Value="editingPlan.CompetenciasFundamentales" class="rich-text-editor" Style="height: 220px;" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Competencias Específicas</label>
                        <RadzenHtmlEditor @bind-Value="editingPlan.CompetenciasEspecificas" class="rich-text-editor" Style="height: 220px;" />
                    </div>
                </div>

                <!-- SECCIÓN 4: CONTENIDOS -->
                <div class="form-section">
                    <div class="form-section-title" style="border-color: #4facfe; color: #4facfe;">
                        📚 Contenidos del Mes (Triangulación)
                    </div>
                    <div class="form-group">
                        <label class="form-label">Conceptuales <span class="required">*</span></label>
                        <RadzenHtmlEditor @bind-Value="editingPlan.ContenidosConceptuales" class="rich-text-editor" Style="height: 220px;" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Procedimentales <span class="required">*</span></label>
                        <RadzenHtmlEditor @bind-Value="editingPlan.ContenidosProcedimentales" class="rich-text-editor" Style="height: 220px;" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Actitudinales <span class="required">*</span></label>
                        <RadzenHtmlEditor @bind-Value="editingPlan.ContenidosActitudinales" class="rich-text-editor" Style="height: 220px;" />
                    </div>
                </div>

                <!-- SECCIÓN 5: EVALUACIÓN -->
                <div class="form-section">
                    <div class="form-section-title" style="border-color: #a18cd1; color: #8e44ad;">
                        ✅ Evaluación e Indicadores
                    </div>
                    <div class="form-group">
                        <label class="form-label">Indicadores de Logro</label>
                        <RadzenHtmlEditor @bind-Value="editingPlan.IndicadoresLogro" class="rich-text-editor" Style="height: 240px;" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Estrategias de Enseñanza</label>
                        <RadzenHtmlEditor @bind-Value="editingPlan.EstrategiasEnsenanza" class="rich-text-editor" Style="height: 220px;" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Recursos Didácticos</label>
                        <RadzenHtmlEditor @bind-Value="editingPlan.RecursosDidacticos" class="rich-text-editor" Style="height: 170px;" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Actividades de Evaluación</label>
                        <RadzenHtmlEditor @bind-Value="editingPlan.ActividadesEvaluacion" class="rich-text-editor" Style="height: 220px;" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Ejes Transversales</label>
                        <RadzenHtmlEditor @bind-Value="editingPlan.EjesTransversales" class="rich-text-editor" Style="height: 170px;" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Observaciones</label>
                        <RadzenHtmlEditor @bind-Value="editingPlan.Observaciones" class="rich-text-editor" Style="height: 170px;" />
                    </div>
                </div>
            </div>

            <div class="form-actions">
                <button class="btn btn-secondary" @onclick="CancelarForm" disabled="@isSubmitting">Cancelar</button>
                <button class="btn btn-primary" @onclick="GuardarMensual" disabled="@isSubmitting">
                    @(isSubmitting ? "Guardando..." : "💾 Guardar Plan Mensual")
                </button>
            </div>
        </div>
    }
</div>

<style>
