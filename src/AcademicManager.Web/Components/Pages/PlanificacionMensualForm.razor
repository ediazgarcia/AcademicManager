@page "/planificaciones/nueva-mensual"
@using AcademicManager.Domain.Entities
@using AcademicManager.Application.Interfaces
@using AcademicManager.Application.Services
@inject NavigationManager Navigation
@inject PlanificacionService PlanificacionService
@inject ILogger<PlanificacionMensualForm> Logger

<div class="planificacion-container">
    <div class="header-section">
        <h1>📅 Crear Planificación Mensual</h1>
        <p class="subtitle">Desglosa la planificación anual en objetivos mensuales específicos</p>
    </div>

    <Microsoft.AspNetCore.Components.Forms.EditForm Model="@planificacionMensual" OnValidSubmit="@GuardarAsync" class="planificacion-form">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <!-- SECCIÓN 1: INFORMACIÓN GENERAL -->
        <div class="form-section">
            <h2>1️⃣ Información General</h2>
            <div class="form-grid">
                <div class="form-group">
                    <label>Mes *</label>
                    <select @bind="planificacionMensual.Mes" class="form-control">
                        <option value="">Seleccione mes...</option>
                        <option>Septiembre</option>
                        <option>Octubre</option>
                        <option>Noviembre</option>
                        <option>Diciembre</option>
                        <option>Enero</option>
                        <option>Febrero</option>
                        <option>Marzo</option>
                        <option>Abril</option>
                        <option>Mayo</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Título de la Unidad *</label>
                    <InputText @bind-Value="planificacionMensual.TituloUnidad" class="form-control" />
                </div>
            </div>
        </div>

        <!-- SECCIÓN 2: SITUACIÓN DE APRENDIZAJE MENSUAL -->
        <div class="form-section">
            <h2>2️⃣ Situación de Aprendizaje</h2>
            <div class="form-group">
                <label>Descripción *</label>
                <InputTextArea @bind-Value="planificacionMensual.SituacionAprendizaje" 
                             class="form-control" rows="5"
                             placeholder="Problema o contexto que motiva el aprendizaje del mes..." />
            </div>
        </div>

        <!-- SECCIÓN 3: COMPETENCIAS MINERD -->
        <div class="form-section">
            <h2>3️⃣ Competencias Mensuales</h2>
            <div class="form-group">
                <label>Competencias Fundamentales *</label>
                <InputTextArea @bind-Value="planificacionMensual.CompetenciasFundamentales" 
                             class="form-control" rows="3" />
            </div>
            <div class="form-group">
                <label>Competencias Específicas *</label>
                <InputTextArea @bind-Value="planificacionMensual.CompetenciasEspecificas" 
                             class="form-control" rows="3" />
            </div>
        </div>

        <!-- SECCIÓN 4: CONTENIDOS -->
        <div class="form-section">
            <h2>4️⃣ Contenidos Mensuales</h2>
            <div class="form-group">
                <label>Contenidos Conceptuales</label>
                <InputTextArea @bind-Value="planificacionMensual.ContenidosConceptuales" 
                             class="form-control" rows="3" />
            </div>
            <div class="form-group">
                <label>Contenidos Procedimentales</label>
                <InputTextArea @bind-Value="planificacionMensual.ContenidosProcedimentales" 
                             class="form-control" rows="3" />
            </div>
            <div class="form-group">
                <label>Contenidos Actitudinales</label>
                <InputTextArea @bind-Value="planificacionMensual.ContenidosActitudinales" 
                             class="form-control" rows="3" />
            </div>
        </div>

        <!-- SECCIÓN 5: INDICADORES DE LOGRO -->
        <div class="form-section">
            <h2>5️⃣ Indicadores de Logro Mensuales</h2>
            <div class="form-group">
                <label>Indicadores *</label>
                <InputTextArea @bind-Value="planificacionMensual.IndicadoresLogro" 
                             class="form-control" rows="5"
                             placeholder="Desempeños esperados del mes..." />
            </div>
        </div>

        <!-- BOTONES -->
        <div class="form-actions">
            <button type="submit" class="btn btn-primary btn-lg">
                💾 Guardar Planificación Mensual
            </button>
            <button type="button" class="btn btn-secondary" @onclick="@(() => Navigation.NavigateTo("/planificaciones"))">
                ❌ Cancelar
            </button>
        </div>
    </Microsoft.AspNetCore.Components.Forms.EditForm>
</div>

@code {
    private PlanificacionMensual planificacionMensual = new();
    private bool isLoading = false;

    private async Task GuardarAsync()
    {
        isLoading = true;
        try
        {
            planificacionMensual.Estado = "Borrador";
            planificacionMensual.FechaCreacion = DateTime.UtcNow;
            
            Logger.LogInformation($"Planificación mensual guardada para {planificacionMensual.Mes}");
            Navigation.NavigateTo("/planificaciones");
        }
        finally
        {
            isLoading = false;
        }
    }
}

<style>
    .planificacion-container {
        max-width: 900px;
        margin: 0 auto;
        padding: 20px;
    }

    .header-section {
        text-align: center;
        margin-bottom: 30px;
        border-bottom: 2px solid #667eea;
        padding-bottom: 15px;
    }

    .header-section h1 {
        color: #333;
        margin: 0;
        font-size: 2em;
    }

    .subtitle {
        color: #666;
        font-size: 1em;
        margin-top: 5px;
    }

    .planificacion-form {
        background: white;
        border-radius: 8px;
        padding: 25px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .form-section {
        margin-bottom: 25px;
        padding-bottom: 20px;
        border-bottom: 1px solid #eee;
    }

    .form-section h2 {
        color: #667eea;
        font-size: 1.2em;
        margin-bottom: 15px;
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 15px;
    }

    .form-group {
        margin-bottom: 15px;
        display: flex;
        flex-direction: column;
    }

    .form-group label {
        font-weight: 600;
        color: #333;
        margin-bottom: 8px;
        font-size: 0.95em;
    }

    .form-control {
        padding: 10px 12px;
        border: 1px solid #ddd;
        border-radius: 4px;
        font-size: 1em;
    }

    .form-control:focus {
        outline: none;
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    }

    .form-actions {
        display: flex;
        gap: 10px;
        margin-top: 30px;
    }

    .btn {
        padding: 12px 24px;
        font-size: 1em;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        transition: all 0.3s;
    }

    .btn-primary {
        background: #667eea;
        color: white;
    }

    .btn-primary:hover {
        background: #5568d3;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
    }

    .btn-secondary {
        background: #f0f0f0;
        color: #333;
    }

    .btn-lg {
        padding: 14px 28px;
        font-size: 1.1em;
    }
</style>
