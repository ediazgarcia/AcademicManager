@page "/alumnos"
@using AcademicManager.Web.Extensions
@using AcademicManager.Web.Constants
@using AcademicManager.Web.Components.Common
@inject AcademicManager.Application.Services.AlumnoService AlumnoService
@inject AcademicManager.Application.Services.GradoService GradoService
@inject AcademicManager.Application.Services.SeccionService SeccionService
@inject IJSRuntime JS
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Alumnos | AcademicManager</PageTitle>

<div class="data-card">
    <div class="data-card-header">
        <div class="d-flex align-center gap-2">
            <h2>👨‍🎓 Gestión de Alumnos</h2>
            <span class="badge badge-primary">@TotalItems Total</span>
        </div>
        <div class="data-card-actions">
            <div class="search-box">
                <input type="text" placeholder="Buscar por nombre, apellido o código..." 
                       @bind="searchTerm" @bind:event="oninput" @onkeyup="OnSearchChanged" />
            </div>
            <button class="btn btn-primary" @onclick="ShowCreateModal">
                <span>+ Nuevo Alumno</span>
            </button>
        </div>
    </div>

    <div class="table-responsive">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Código</th>
                    <th>Apellidos y Nombres</th>
                    <th>Grado/Sección</th>
                    <th>Contacto</th>
                    <th>Estado</th>
                    <th class="text-right">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (isLoading)
                {
                    <tr>
                        <td colspan="6" class="text-center p-3">
                            <div class="spinner"></div>
                        </td>
                    </tr>
                }
                else if (!PaginatedAlumnos.Any())
                {
                    <tr>
                        <td colspan="6">
                            <div class="empty-state">
                                <div class="empty-state-icon">📚</div>
                                <div class="empty-state-text">No se encontraron alumnos</div>
                                <div class="empty-state-subtext">
                                    @if (!string.IsNullOrWhiteSpace(searchTerm))
                                    {
                                        <span>Intenta con otro término de búsqueda</span>
                                    }
                                    else
                                    {
                                        <span>Comienza agregando tu primer alumno</span>
                                    }
                                </div>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var a in PaginatedAlumnos)
                    {
                        <tr class="@GetRowClass(a)">
                            <td><span class="badge badge-info">@a.Codigo</span></td>
                            <td class="fw-bold">@a.Apellidos, @a.Nombres</td>
                            <td>
                                @{
                                    var grado = grados.FirstOrDefault(g => g.Id == a.GradoId);
                                    var seccion = allSecciones.FirstOrDefault(s => s.Id == a.SeccionId);
                                }
                                @if (grado != null)
                                {
                                    <span>@grado.Nombre</span>
                                }
                                @if (seccion != null)
                                {
                                    <span class="badge badge-sm badge-secondary ms-1">@seccion.Nombre</span>
                                }
                            </td>
                            <td><small>@a.Email<br/>@a.Telefono</small></td>
                            <td>
                                @if (a.Activo)
                                {
                                    <span class="badge badge-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge badge-secondary">Inactivo</span>
                                }
                            </td>
                            <td class="text-right">
                                <button class="btn btn-ghost btn-sm" @onclick="() => Edit(a)" title="Editar">✏️</button>
                                <button class="btn btn-ghost btn-sm text-danger" @onclick="() => ShowDeleteConfirmation(a.Id)" title="Eliminar">🗑️</button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
    
    @if (TotalItems > 0)
    {
        <Pagination CurrentPage="@currentPage" 
                    PageSize="@pageSize" 
                    TotalItems="@TotalItems"
                    OnPageChanged="HandlePageChanged"
                    OnPageSizeChanged="HandlePageSizeChanged" />
    }
</div>

@if (showModal)
{
    <div class="modal-overlay" @onclick="@(() => { if (!isSubmitting) CloseModal(); })">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>@(editingAlumno.Id == 0 ? "Nuevo Alumno" : "Editar Alumno")</h3>
                <button class="btn btn-ghost btn-icon" @onclick="CloseModal" disabled="@isSubmitting">✕</button>
            </div>
            
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-error">@errorMessage</div>
                }
                
                <div class="form-group">
                    <label>Código <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" @bind="editingAlumno.Codigo" required />
                </div>

                <div class="form-group">
                    <label>Nombres <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" @bind="editingAlumno.Nombres" required />
                </div>

                <div class="form-group">
                    <label>Apellidos <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" @bind="editingAlumno.Apellidos" required />
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Fecha de Nacimiento <span class="text-danger">*</span></label>
                        <input type="date" class="form-control" @bind="editingAlumno.FechaNacimiento" required />
                    </div>

                    <div class="form-group">
                        <label>Género <span class="text-danger">*</span></label>
                        <select class="form-control" @bind="editingAlumno.Genero">
                            <option value="Masculino">Masculino</option>
                            <option value="Femenino">Femenino</option>
                            <option value="Otro">Otro</option>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label>Dirección</label>
                    <input type="text" class="form-control" @bind="editingAlumno.Direccion" />
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Teléfono</label>
                        <input type="tel" class="form-control" @bind="editingAlumno.Telefono" />
                    </div>

                    <div class="form-group">
                        <label>Email</label>
                        <input type="email" class="form-control" @bind="editingAlumno.Email" />
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Nombre del Apoderado</label>
                        <input type="text" class="form-control" @bind="editingAlumno.NombreApoderado" />
                    </div>

                    <div class="form-group">
                        <label>Teléfono del Apoderado</label>
                        <input type="tel" class="form-control" @bind="editingAlumno.TelefonoApoderado" />
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Grado</label>
                        <select class="form-control" @onchange="OnGradoChanged">
                            <option value="">Seleccionar Grado</option>
                            @foreach (var grado in grados)
                            {
                                <option value="@grado.Id" selected="@(editingAlumno.GradoId == grado.Id)">@grado.Nombre</option>
                            }
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Sección</label>
                        <select class="form-control" @bind="editingAlumno.SeccionId" disabled="@(!editingAlumno.GradoId.HasValue)">
                            <option value="">Seleccionar Sección</option>
                            @foreach (var seccion in filteredSecciones)
                            {
                                var grado = grados.FirstOrDefault(g => g.Id == seccion.GradoId);
                                <option value="@seccion.Id">@seccion.Nombre @(grado != null ? $"- {grado.Nombre}" : "")</option>
                            }
                        </select>
                    </div>
                </div>

                @if (editingAlumno.Id > 0)
                {
                    <div class="form-group">
                        <div class="form-check mt-2">
                            <label class="d-flex align-center gap-2 cursor-pointer">
                                <input type="checkbox" @bind="editingAlumno.Activo" />
                                <span>Alumno Activo</span>
                            </label>
                        </div>
                    </div>
                }
            </div>
            
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" @onclick="CloseModal" disabled="@isSubmitting">Cancelar</button>
                <button type="button" class="btn btn-primary" @onclick="Save" disabled="@isSubmitting">
                    @if (isSubmitting)
                    {
                        <span class="spinner spinner-sm me-2"></span>
                        <span>Guardando...</span>
                    }
                    else
                    {
                        <span>Guardar</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

<!-- Confirmation Modal -->
<Modal Show="showDeleteConfirm"
        Title="🗑️ Confirmar Eliminación"
        Size="sm"
        ShowCloseButton="true"
        ShowChanged="OnDeleteModalShowChanged">
    <ChildContent>
        <div class="confirm-delete">
            <div class="confirm-icon">⚠️</div>
            <div class="confirm-message">
                <p>¿Está seguro de eliminar este alumno?</p>
                <p class="confirm-subtitle">Esta acción no se puede deshacer.</p>
            </div>
        </div>
    </ChildContent>
    <FooterContent>
        <button class="btn btn-secondary" @onclick="CancelDeleteAsync">Cancelar</button>
        <button class="btn btn-danger" @onclick="ConfirmDeleteAsync" disabled="@isDeleting">
            @if (isDeleting)
            {
                <span class="spinner spinner-sm"></span>
            }
            else
            {
                <span>Eliminar</span>
            }
        </button>
    </FooterContent>
</Modal>

@code {
    private List<AcademicManager.Domain.Entities.Alumno> allAlumnos = new();
    private List<AcademicManager.Domain.Entities.Alumno> filteredAlumnos = new();
    private List<AcademicManager.Domain.Entities.Grado> grados = new();
    private List<AcademicManager.Domain.Entities.Seccion> allSecciones = new();
    private List<AcademicManager.Domain.Entities.Seccion> filteredSecciones = new();
    
    private AcademicManager.Domain.Entities.Alumno editingAlumno = new();
    private bool showModal = false;
    private bool showDeleteConfirm = false;
    private bool isLoading = true;
    private bool isSubmitting = false;
    private bool isDeleting = false;
    private string searchTerm = "";
    private string errorMessage = "";
    private int? deletingId = null;

    private bool IsSubmitting => isSubmitting;
    
    private int currentPage = 1;
    private int pageSize = 10;

    protected override async Task OnInitializedAsync()
    {
        await LoadMetadataAsync();
        await LoadDataAsync();
    }

    private async Task LoadMetadataAsync()
    {
        try
        {
            var gradoTask = GradoService.ObtenerTodosAsync();
            var seccionTask = SeccionService.ObtenerTodosAsync();

            await Task.WhenAll(gradoTask, seccionTask);

            grados = gradoTask.Result.ToList();
            allSecciones = seccionTask.Result.ToList();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al cargar datos: {ex.Message}";
        }
    }

    private async Task LoadDataAsync()
    {
        try
        {
            isLoading = true;
            var result = await AlumnoService.ObtenerTodosAsync();
            allAlumnos = result.ToList();
            ApplyFilter();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al cargar alumnos: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ApplyFilter()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            filteredAlumnos = allAlumnos.ToList();
        }
        else
        {
            var term = searchTerm.ToLower();
            filteredAlumnos = allAlumnos.Where(a => 
                a.Codigo.ToLower().Contains(term) ||
                a.Nombres.ToLower().Contains(term) ||
                a.Apellidos.ToLower().Contains(term) ||
                (a.Email?.ToLower().Contains(term) ?? false)
            ).ToList();
        }
        currentPage = 1;
    }

    private IEnumerable<AcademicManager.Domain.Entities.Alumno> PaginatedAlumnos =>
        filteredAlumnos.Skip((currentPage - 1) * pageSize).Take(pageSize);

    private int TotalItems => filteredAlumnos.Count;

    private string GetRowClass(AcademicManager.Domain.Entities.Alumno a) => "";

    private void OnSearchChanged() => ApplyFilter();

    private async Task HandlePageChanged(int page)
    {
        currentPage = page;
        await Task.CompletedTask;
    }

    private async Task HandlePageSizeChanged(int size)
    {
        pageSize = size;
        currentPage = 1;
        await Task.CompletedTask;
    }

    private void ShowCreateModal()
    {
        editingAlumno = new AcademicManager.Domain.Entities.Alumno 
        { 
            Activo = true,
            FechaNacimiento = DateTime.Today.AddYears(-10),
            Genero = "Masculino"
        };
        filteredSecciones = new();
        errorMessage = "";
        showModal = true;
    }

    private void Edit(AcademicManager.Domain.Entities.Alumno item)
    {
        editingAlumno = new AcademicManager.Domain.Entities.Alumno
        {
            Id = item.Id,
            Codigo = item.Codigo,
            Nombres = item.Nombres,
            Apellidos = item.Apellidos,
            FechaNacimiento = item.FechaNacimiento,
            Genero = item.Genero,
            Direccion = item.Direccion,
            Telefono = item.Telefono,
            Email = item.Email,
            NombreApoderado = item.NombreApoderado,
            TelefonoApoderado = item.TelefonoApoderado,
            GradoId = item.GradoId,
            SeccionId = item.SeccionId,
            Activo = item.Activo
        };

        if (editingAlumno.GradoId.HasValue)
        {
            filteredSecciones = allSecciones.Where(s => s.GradoId == editingAlumno.GradoId.Value).ToList();
        }
        
        errorMessage = "";
        showModal = true;
    }

    private void OnGradoChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var gradoId) && gradoId > 0)
        {
            editingAlumno.GradoId = gradoId;
            filteredSecciones = allSecciones.Where(s => s.GradoId == gradoId).ToList();
            editingAlumno.SeccionId = null;
        }
        else
        {
            editingAlumno.GradoId = null;
            filteredSecciones = new List<AcademicManager.Domain.Entities.Seccion>();
            editingAlumno.SeccionId = null;
        }
    }

    private void ShowDeleteConfirmation(int id)
    {
        deletingId = id;
        showDeleteConfirm = true;
    }

    private async Task OnDeleteModalShowChanged(bool show)
    {
        if (!show && !isDeleting)
        {
            showDeleteConfirm = false;
            deletingId = null;
        }
        await Task.CompletedTask;
    }

    private async Task CancelDeleteAsync()
    {
        showDeleteConfirm = false;
        deletingId = null;
        await Task.CompletedTask;
    }

    private async Task ConfirmDeleteAsync()
    {
        if (!deletingId.HasValue) return;
        
        try
        {
            isDeleting = true;
            await AlumnoService.EliminarAsync(deletingId.Value);
            showDeleteConfirm = false;
            deletingId = null;
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al eliminar: {ex.Message}";
        }
        finally
        {
            isDeleting = false;
        }
    }

    private void CloseModal()
    {
        showModal = false;
        errorMessage = "";
    }

    private async Task Save()
    {
        try
        {
            isSubmitting = true;
            errorMessage = "";

            editingAlumno.Grado = null;
            editingAlumno.Seccion = null;

            if (editingAlumno.Id == 0)
            {
                await AlumnoService.CrearAsync(editingAlumno);
            }
            else
            {
                await AlumnoService.ActualizarAsync(editingAlumno);
            }

            showModal = false;
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al guardar: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
