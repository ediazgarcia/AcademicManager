@page "/coordinador/reporteria"
@attribute [Authorize(Roles = "Admin,Coordinador")]
@using AcademicManager.Application.DTOs
@using AcademicManager.Application.Services
@using AcademicManager.Web.Components.Coordinator
@using Microsoft.AspNetCore.Authorization
@inject CoordinadorService CoordinadorService
@inject ILogger<CoordinadorReporteria> Logger
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Reportería | AcademicManager</PageTitle>

<div class="ops-page">
    @if (isLoading)
    {
        <div class="ops-empty">
            <div class="spinner"></div>
            <p>Cargando datos de reportería...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-error">
            <strong>Error:</strong> @errorMessage
        </div>
    }
    else if (reporteData != null)
    {
        @* Hero Section *@
        <section class="ops-hero">
            <div class="ops-copy">
                <span class="ops-kicker">Centro de Reportería</span>
                <h2>Dashboard de Aprobaciones</h2>
                <p>Monitoreo centralizado de planificaciones por período con análisis de tendencias y alertas críticas.</p>
            </div>

            <div class="ops-stack">
                @if (reporteData.Alertas?.Count > 0)
                {
                    <article class="ops-alert severity-danger">
                        <div>
                            <strong>@reporteData.Alertas.Count plan(es) vencido(s)</strong>
                            <p>Requieren revisión y aprobación inmediata.</p>
                        </div>
                        <a href="#alertas-section">Ver alertas</a>
                    </article>
                }
                @if (reporteData.Enviadas > reporteData.Aprobadas)
                {
                    <article class="ops-alert severity-warning">
                        <div>
                            <strong>@(reporteData.Enviadas - reporteData.Aprobadas) plan(es) pendiente(s)</strong>
                            <p>En espera de revisión y aprobación.</p>
                        </div>
                        <a href="#alertas-section">Revisar</a>
                    </article>
                }
                else
                {
                    <article class="ops-alert severity-success">
                        <div>
                            <strong>✓ Período al día</strong>
                            <p>Todas las planificaciones han sido procesadas.</p>
                        </div>
                    </article>
                }
            </div>
        </section>

        @* Metric Cards *@
        <section class="ops-metric-grid">
            <MetricCard
                Label="Total"
                Value="@reporteData.TotalPlanificaciones.ToString()"
                Detail="Planificaciones en el período"
                Tone="primary"
                Icon="📋" />

            <MetricCard
                Label="Aprobación Global"
                Value="@reporteData.TasaAprobacionGlobal.ToString("0.0")%"
                Detail="Tasa de aprobación general"
                Tone="success"
                Icon="✓" />

            <MetricCard
                Label="Pendientes"
                Value="@reporteData.Enviadas.ToString()"
                Detail="Aún esperan revisión"
                Tone="warning"
                Icon="⏳" />

            <MetricCard
                Label="Críticos"
                Value="@(reporteData.Alertas?.Count ?? 0).ToString()"
                Detail="Requieren acción inmediata"
                Tone="danger"
                Icon="⚠️" />
        </section>

        @* Filters *@
        <ReportFiltersPanel
            SelectedPeriodo="selectedPeriodoId"
            SelectedGrado="selectedGradoId"
            SelectedEstado="selectedEstado"
            OnPeriodoChanged="OnPeriodoChanged"
            OnGradoChanged="OnGradoChanged"
            OnEstadoChanged="OnEstadoChanged" />

        @* Charts Section *@
        <section class="ops-section">
            <div class="ops-section-head">
                <div>
                    <span class="ops-kicker">Análisis Visual</span>
                    <h3>Tendencias y Distribuciones</h3>
                </div>
                <div>
                    <ExportReportButton
                        IsLoading="isExporting"
                        OnExportClick="ExportToExcel" />
                </div>
            </div>

            <div class="charts-grid">
                <div class="chart-column">
                    <AprobacionChart
                        TimelineData="@reporteData.Timeline"
                        ChartTitle="Tendencia de Aprobaciones en el Período"
                        ShowLegend="true" />
                </div>

                @if (reporteData.RegresionDocentes?.Count > 0)
                {
                    <div class="chart-column">
                        <DocenteRegressionChart
                            DocenteData="@reporteData.RegresionDocentes.Take(10).ToList()"
                            ChartTitle="Desempeño de Docentes (Top 10)" />
                    </div>
                }
            </div>
        </section>

        @* Status Distribution *@
        @if (reporteData.EstadisticasPorEstado?.Count > 0)
        {
            <section class="ops-section">
                <div class="ops-section-head">
                    <span class="ops-kicker">Estados</span>
                    <h3>Distribución de Planificaciones</h3>
                </div>

                <div class="status-distribution">
                    @foreach (var stat in reporteData.EstadisticasPorEstado)
                    {
                        <div class="status-item">
                            <div class="status-header">
                                <span class="status-label">@stat.Estado</span>
                                <span class="status-count">@stat.Cantidad</span>
                            </div>
                            <div class="status-bar">
                                <div class="status-fill @GetStatusClass(stat.Estado)"
                                     style="width: @stat.Porcentaje%">
                                </div>
                            </div>
                            <div class="status-percentage">@stat.Porcentaje.ToString("0.0")%</div>
                        </div>
                    }
                </div>
            </section>
        }

        @* Alerts Section *@
        <section id="alertas-section">
            <ExpiredAlertsPanel
                Alertas="@reporteData.Alertas"
                PageSize="5" />
        </section>
    }
</div>

@code {
    private ReporteAprobacionesDto reporteData;
    private bool isLoading = true;
    private bool isExporting = false;
    private string errorMessage = string.Empty;

    private int selectedPeriodoId = 1;
    private int? selectedGradoId;
    private string selectedEstado = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadReportingData();
    }

    private async Task LoadReportingData()
    {
        try
        {
            isLoading = true;
            errorMessage = string.Empty;

            reporteData = await CoordinadorService.GetDashboardDataAsync(selectedPeriodoId);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading reporting data");
            errorMessage = $"No se pudieron cargar los datos: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OnPeriodoChanged(int periodoId)
    {
        selectedPeriodoId = periodoId;
        await LoadReportingData();
    }

    private async Task OnGradoChanged(int? gradoId)
    {
        selectedGradoId = gradoId;
        // In a real implementation, would filter data by grade
    }

    private async Task OnEstadoChanged(string estado)
    {
        selectedEstado = estado;
        // In a real implementation, would filter data by status
    }

    private async Task ExportToExcel()
    {
        try
        {
            isExporting = true;

            // In a real implementation, would call ReportingService.ExportToExcelAsync()
            // For now, just show a notification
            Logger.LogInformation("Export to Excel initiated");
            await Task.Delay(1500); // Simulate export process
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error exporting to Excel");
            errorMessage = "No se pudo exportar el reporte";
        }
        finally
        {
            isExporting = false;
        }
    }

    private string GetStatusClass(string estado) => estado switch
    {
        "Aprobado" => "status-approved",
        "Enviado" => "status-sent",
        "Rechazado" => "status-rejected",
        "Borrador" => "status-draft",
        _ => "status-default"
    };
}

<style>
    .charts-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(500px, 1fr));
        gap: 2rem;
    }

    .chart-column {
        min-width: 0;
    }

    .status-distribution {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        padding: 1.5rem;
        background: var(--workspace-panel);
        border-radius: var(--workspace-radius-md);
        border: 1px solid var(--workspace-border);
    }

    .status-item {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .status-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .status-label {
        font-weight: 600;
        color: var(--workspace-text);
    }

    .status-count {
        display: inline-block;
        padding: 0.25rem 0.75rem;
        background: rgba(15, 140, 121, 0.1);
        border-radius: 0.25rem;
        font-weight: 600;
        font-size: 0.875rem;
        color: #0f8c79;
    }

    .status-bar {
        height: 24px;
        background: #e8e8e8;
        border-radius: 0.25rem;
        overflow: hidden;
    }

    .status-fill {
        height: 100%;
        transition: width 0.3s ease;
        border-radius: 0.25rem;
    }

    .status-approved {
        background: #2c8c62;
    }

    .status-sent {
        background: #d48f27;
    }

    .status-rejected {
        background: #ca5848;
    }

    .status-draft {
        background: #888;
    }

    .status-default {
        background: #666;
    }

    .status-percentage {
        font-size: 0.875rem;
        color: var(--workspace-text-secondary);
        font-weight: 500;
    }

    .alert-error {
        padding: 1rem 1.5rem;
        background: rgba(202, 88, 72, 0.1);
        border-left: 4px solid #ca5848;
        border-radius: var(--workspace-radius-md);
        color: #ca5848;
        margin: 1.5rem 0;
    }

    .alert-error strong {
        display: block;
        margin-bottom: 0.5rem;
    }

    @media (max-width: 1024px) {
        .charts-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
