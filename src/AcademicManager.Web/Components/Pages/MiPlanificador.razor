@page "/planificador"
@attribute [Authorize(Roles = "Admin,Coordinador,Docente")]
@using AcademicManager.Application.DTOs
@using Microsoft.AspNetCore.Authorization
@inject AcademicManager.Application.Services.AcademicWorkspaceService WorkspaceService
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager Navigation
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Planificador | AcademicManager</PageTitle>

@if (isLoading)
{
    <div class="ops-section">
        <div class="ops-empty">
            <div class="spinner"></div>
            <p>Cargando el flujo de planificacion...</p>
        </div>
    </div>
}
else
{
    <div class="plan-page">
        <section class="ops-hero ops-hero-tonal">
            <div class="ops-copy">
                <span class="ops-kicker">@periodoActivo</span>
                <h2>@heroTitle</h2>
                <p>@heroSubtitle</p>
            </div>

            <div class="ops-stack">
                @foreach (var alert in alerts.Take(3))
                {
                    <article class="ops-alert severity-@alert.Severity">
                        <div>
                            <strong>@alert.Title</strong>
                            <p>@alert.Description</p>
                        </div>
                        <a href="@alert.Href">@alert.LinkLabel</a>
                    </article>
                }
            </div>
        </section>

        <section class="ops-metric-grid">
            <article class="ops-metric-card tone-primary">
                <div class="metric-topline">
                    <span class="ops-kicker">Cursos</span>
                    <span class="ops-metric-chip">CU</span>
                </div>
                <strong class="ops-metric-value">@planning.Count</strong>
                <span>Rutas visibles en el planificador.</span>
            </article>
            <article class="ops-metric-card tone-success">
                <div class="metric-topline">
                    <span class="ops-kicker">Aprobado</span>
                    <span class="ops-metric-chip">AP</span>
                </div>
                <strong class="ops-metric-value">@planning.Count(item => item.EstadoPrincipal == "Aprobado")</strong>
                <span>Cursos con planificacion aprobada.</span>
            </article>
            <article class="ops-metric-card tone-warning">
                <div class="metric-topline">
                    <span class="ops-kicker">Revision</span>
                    <span class="ops-metric-chip">RV</span>
                </div>
                <strong class="ops-metric-value">@planning.Sum(item => item.PlanesEnviados)</strong>
                <span>Planes esperando validacion.</span>
            </article>
            <article class="ops-metric-card tone-danger">
                <div class="metric-topline">
                    <span class="ops-kicker">Cobertura</span>
                    <span class="ops-metric-chip">CV</span>
                </div>
                <strong class="ops-metric-value">@averageCoverage%</strong>
                <span>Promedio de avance del flujo planificado.</span>
            </article>
        </section>

        <section class="ops-section">
            <div class="ops-section-head">
                <div>
                    <span class="ops-kicker">Pipeline</span>
                    <h3>@(isCoordinatorLike ? "Revision institucional" : "Ruta de planificacion por curso")</h3>
                </div>
            </div>

            @if (!planning.Any())
            {
                <div class="ops-empty">No hay cursos disponibles para tu contexto actual.</div>
            }
            else
            {
                <div class="ops-card-grid">
                    @foreach (var item in planning)
                    {
                        <article class="ops-planning-card">
                            <div class="ops-filterbar">
                                <strong>@item.CursoNombre</strong>
                                <span class="ops-badge @GetPlanningTone(item.EstadoPrincipal)">@item.EstadoPrincipal</span>
                            </div>
                            <span>@item.CodigoCurso · @item.DocenteLabel</span>
                            <span>@item.SeccionLabel · @item.EstudiantesImpactados estudiante(s)</span>
                            <div class="ops-progress">
                                <span style="width:@item.Cobertura%"></span>
                            </div>
                            <span><strong>Cobertura:</strong> @item.Cobertura%</span>
                            <span><strong>Proximo paso:</strong> @item.ProximoPaso</span>
                            <button class="btn btn-primary btn-sm" @onclick="() => OpenPlanning(item)">Abrir flujo</button>
                        </article>
                    }
                </div>
            }
        </section>
    </div>
}

@code {
    private List<PlanningCourseSummary> planning = new();
    private List<WorkspaceAlert> alerts = new();
    private bool isLoading = true;
    private string currentRole = string.Empty;
    private int? currentDocenteId;
    private int? currentAlumnoId;
    private string periodoActivo = "Sin periodo activo";

    private bool isCoordinatorLike =>
        string.Equals(currentRole, "Admin", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(currentRole, "Coordinador", StringComparison.OrdinalIgnoreCase);

    private string heroTitle => isCoordinatorLike
        ? "Control de planificacion del centro"
        : "Mi flujo de planificacion docente";

    private string heroSubtitle => isCoordinatorLike
        ? "Aqui ves aprobaciones, huecos operativos y cursos que necesitan empuje desde coordinacion."
        : "Avanza desde el plan anual hasta la clase diaria con una sola vista de control.";

    private int averageCoverage => planning.Any() ? (int)Math.Round(planning.Average(item => item.Cobertura)) : 0;

    protected override async Task OnInitializedAsync()
    {
        var session = HttpContextAccessor.HttpContext?.Session;
        currentRole = session?.GetString("UserRole") ?? string.Empty;
        currentDocenteId = session?.GetInt32("DocenteId");
        currentAlumnoId = session?.GetInt32("AlumnoId");

        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;

        try
        {
            var snapshot = await WorkspaceService.ObtenerPanelPrincipalAsync(currentRole, currentDocenteId, currentAlumnoId);
            periodoActivo = snapshot.PeriodoActivo;
            alerts = snapshot.Alerts.ToList();
            planning = (await WorkspaceService.ObtenerResumenPlanificacionAsync(currentRole, currentDocenteId, currentAlumnoId)).ToList();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OpenPlanning(PlanningCourseSummary item)
    {
        if (item.PlanAnualId.HasValue)
        {
            Navigation.NavigateTo($"/planificador/anual/{item.PlanAnualId.Value}/mensual");
            return;
        }

        Navigation.NavigateTo($"/planificador/cursos/{item.CursoId}/anual");
    }

    private static string GetPlanningTone(string status) => status switch
    {
        "Aprobado" => "tone-success",
        "Por revisar" => "tone-warning",
        "En borrador" => "tone-primary",
        _ => "tone-danger"
    };
}
