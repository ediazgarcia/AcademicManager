        background: #f9f9f9;
    }

    .course-header-info {
        flex: 1;
    }

    .course-name {
        margin: 0;
        font-size: 1.2rem;
        color: #333;
    }

    .instructor {
        margin: 4px 0 0;
        font-size: 0.9rem;
        color: #999;
    }

    .course-final-grade {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        padding: 12px 24px;
        background: white;
        border-radius: 6px;
    }

    .grade-label {
        font-size: 0.8rem;
        color: #999;
        text-transform: uppercase;
        font-weight: 600;
    }

    .grade-value {
        font-size: 2rem;
        font-weight: 700;
        color: #666;
    }

    .grade-excellent { color: #1b5e20; }
    .grade-good { color: #0d47a1; }
    .grade-passed { color: #558b2f; }
    .grade-warning { color: #e65100; }
    .grade-failed { color: #b71c1c; }

    .card-content {
        padding: 20px;
    }

    .grades-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.95rem;
    }

    .grades-table thead {
        background: #f5f5f5;
    }

    .grades-table th {
        padding: 12px;
        text-align: left;
        font-weight: 600;
        color: #666;
        border-bottom: 2px solid #e0e0e0;
    }

    .grades-table td {
        padding: 12px;
        border-bottom: 1px solid #f0f0f0;
    }

    .grades-table tbody tr.passed {
        background: rgba(27, 94, 32, 0.02);
    }

    .grades-table tbody tr.failed {
        background: rgba(183, 28, 28, 0.02);
    }

    .component-grade {
        font-weight: 600;
        color: #333;
    }

    .component-weight,
    .component-contribution {
        text-align: right;
        font-family: monospace;
    }

    .card-footer {
        display: flex;
        gap: 24px;
        padding: 16px 20px;
        background: #f9f9f9;
        border-top: 1px solid #e0e0e0;
    }

    .footer-stat {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .footer-stat span {
        font-size: 0.8rem;
        color: #999;
        text-transform: uppercase;
        font-weight: 600;
    }

    .footer-stat strong {
        font-size: 1rem;
        color: #333;
    }

    .status-passed {
        color: #1b5e20;
    }

    .status-failed {
        color: #b71c1c;
    }

    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 48px 24px;
        text-align: center;
