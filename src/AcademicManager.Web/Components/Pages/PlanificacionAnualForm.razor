@page "/planificaciones/nueva-anual"
@using AcademicManager.Domain.Entities
@using AcademicManager.Application.Interfaces
@using AcademicManager.Application.Services
@using Radzen.Blazor
@inject NavigationManager Navigation
@inject PlanificacionService PlanificacionService
@inject ILogger<PlanificacionAnualForm> Logger

<div class="planificacion-container">
    <div class="header-section">
        <h1>📋 Crear Planificación Anual</h1>
        <p class="subtitle">Estructura MINERD - Competencias, Contenidos e Indicadores de Logro</p>
    </div>

    <Microsoft.AspNetCore.Components.Forms.EditForm Model="@planificacion" OnValidSubmit="@GuardarAsync" class="planificacion-form">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <!-- SECCIÓN 1: IDENTIFICACIÓN -->
        <div class="form-section">
            <h2>1️⃣ Identificación</h2>
            <div class="form-grid">
                <div class="form-group">
                    <label>Año Académico *</label>
                    <InputNumber @bind-Value="planificacion.AnoAcademico" class="form-control" />
                </div>
                <div class="form-group">
                    <label>Título de la Unidad *</label>
                    <InputText @bind-Value="planificacion.TituloUnidad" class="form-control" placeholder="Ej: Números Naturales" />
                </div>
                <div class="form-group">
                    <label>Mes *</label>
                    <select @bind="planificacion.Mes" class="form-control">
                        <option value="">Seleccione mes...</option>
                        <option>Septiembre</option>
                        <option>Octubre</option>
                        <option>Noviembre</option>
                        <option>Diciembre</option>
                        <option>Enero</option>
                        <option>Febrero</option>
                        <option>Marzo</option>
                        <option>Abril</option>
                        <option>Mayo</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- SECCIÓN 2: SITUACIÓN DE APRENDIZAJE -->
        <div class="form-section">
            <h2>2️⃣ Situación de Aprendizaje</h2>
            <div class="form-group">
                <label>Descripción de la Situación *</label>
                <RadzenHtmlEditor @bind-Value="planificacion.SituacionAprendizaje" class="rich-text-editor" Style="height: 260px;" />
            </div>
        </div>

        <!-- SECCIÓN 3: COMPETENCIAS MINERD -->
        <div class="form-section">
            <h2>3️⃣ Competencias</h2>
            <div class="form-group">
                <label>Competencias Fundamentales *</label>
                <RadzenHtmlEditor @bind-Value="planificacion.CompetenciasFundamentales" class="rich-text-editor" Style="height: 240px;" />
                <small>Desarrollan integralmente la personalidad del estudiante</small>
            </div>
            <div class="form-group">
                <label>Competencias Específicas *</label>
                <RadzenHtmlEditor @bind-Value="planificacion.CompetenciasEspecificas" class="rich-text-editor" Style="height: 240px;" />
                <small>Particulares del dominio específico</small>
            </div>
        </div>

        <!-- SECCIÓN 4: CONTENIDOS (TRIANGULACIÓN) -->
        <div class="form-section">
            <h2>4️⃣ Contenidos (Triangulación de Aprendizajes)</h2>
            <div class="form-group">
                <label>Contenidos Conceptuales *</label>
                <RadzenHtmlEditor @bind-Value="planificacion.ContenidosConceptuales" class="rich-text-editor" Style="height: 220px;" />
                <small>¿Qué debe saber el estudiante?</small>
            </div>
            <div class="form-group">
                <label>Contenidos Procedimentales *</label>
                <RadzenHtmlEditor @bind-Value="planificacion.ContenidosProcedimentales" class="rich-text-editor" Style="height: 220px;" />
                <small>¿Qué debe saber hacer?</small>
            </div>
            <div class="form-group">
                <label>Contenidos Actitudinales *</label>
                <RadzenHtmlEditor @bind-Value="planificacion.ContenidosActitudinales" class="rich-text-editor" Style="height: 220px;" />
                <small>¿Qué debe ser? (Formación integral)</small>
            </div>
        </div>

        <!-- SECCIÓN 5: INDICADORES DE LOGRO -->
        <div class="form-section">
            <h2>5️⃣ Indicadores de Logro</h2>
            <div class="form-group">
                <label>Indicadores de Logro *</label>
                <RadzenHtmlEditor @bind-Value="planificacion.IndicadoresLogro" class="rich-text-editor" Style="height: 260px;" />
                <small>Formulados en términos de desempeños observables y medibles</small>
            </div>
        </div>

        <!-- SECCIÓN 6: ESTRATEGIAS Y RECURSOS -->
        <div class="form-section">
            <h2>6️⃣ Estrategias y Recursos</h2>
            <div class="form-group">
                <label>Estrategias de Enseñanza *</label>
                <RadzenHtmlEditor @bind-Value="planificacion.EstrategiasEnsenanza" class="rich-text-editor" Style="height: 240px;" />
            </div>
            <div class="form-group">
                <label>Recursos Didácticos *</label>
                <RadzenHtmlEditor @bind-Value="planificacion.RecursosDidacticos" class="rich-text-editor" Style="height: 220px;" />
            </div>
            <div class="form-group">
                <label>Ejes Transversales</label>
                <RadzenHtmlEditor @bind-Value="planificacion.EjesTransversales" class="rich-text-editor" Style="height: 220px;" />
            </div>
        </div>

        <!-- SECCIÓN 7: EVALUACIÓN -->
        <div class="form-section">
            <h2>7️⃣ Evaluación</h2>
            <div class="form-group">
                <label>Actividades de Evaluación *</label>
                <RadzenHtmlEditor @bind-Value="planificacion.ActividadesEvaluacion" class="rich-text-editor" Style="height: 240px;" />
            </div>
            <div class="form-group">
                <label>Criterios de Evaluación</label>
                <RadzenHtmlEditor @bind-Value="planificacion.CriteriosEvaluacion" class="rich-text-editor" Style="height: 220px;" />
            </div>
        </div>

        <!-- SECCIÓN 8: OBSERVACIONES -->
        <div class="form-section">
            <h2>8️⃣ Observaciones</h2>
            <div class="form-group">
                <label>Notas Adicionales</label>
                <RadzenHtmlEditor @bind-Value="planificacion.Observaciones" class="rich-text-editor" Style="height: 220px;" />
            </div>
        </div>

        <!-- BOTONES -->
        <div class="form-actions">
            <button type="submit" class="btn btn-primary btn-lg" disabled="@isLoading">
                @(isLoading ? "⏳ Guardando..." : "💾 Guardar como Borrador")
            </button>
            <button type="button" class="btn btn-secondary" @onclick="@(() => Navigation.NavigateTo("/planificaciones"))" disabled="@isLoading">
                ❌ Cancelar
            </button>
        </div>
    </Microsoft.AspNetCore.Components.Forms.EditForm>
</div>

@code {
    private Planificacion planificacion = new();
    private bool isLoading = false;

    protected override void OnInitialized()
    {
        // Inicializar con valores por defecto
        planificacion.Estado = "Borrador";
        planificacion.TipoplanificacionAcademico = "Anual";
        planificacion.AnoAcademico = DateTime.Now.Year;
    }

    private async Task GuardarAsync()
    {
        isLoading = true;
        try
        {
            // Validación básica
            if (string.IsNullOrEmpty(planificacion.Titulo))
            {
                Logger.LogError("El título es obligatorio");
                return;
            }

            Logger.LogInformation("Planificación guardada como borrador");
            Navigation.NavigateTo("/planificaciones");
        }
        finally
        {
            isLoading = false;
        }
    }
}

<style>
    .planificacion-container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 20px;
    }

    .header-section {
        text-align: center;
        margin-bottom: 30px;
        border-bottom: 2px solid #667eea;
        padding-bottom: 15px;
    }

    .header-section h1 {
        color: #333;
        margin: 0;
        font-size: 2em;
    }

    .subtitle {
        color: #666;
        font-size: 1.1em;
        margin-top: 5px;
    }

    .planificacion-form {
        background: white;
        border-radius: 8px;
        padding: 25px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .form-section {
        margin-bottom: 30px;
        padding-bottom: 20px;
        border-bottom: 1px solid #eee;
    }

    .form-section h2 {
        color: #667eea;
        font-size: 1.3em;
        margin-bottom: 15px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 15px;
    }

    .form-group {
        margin-bottom: 15px;
        display: flex;
        flex-direction: column;
    }

    .form-group label {
        font-weight: 600;
        color: #333;
        margin-bottom: 8px;
        font-size: 0.95em;
    }

    .form-group small {
        color: #999;
        font-style: italic;
        margin-top: 5px;
        font-size: 0.85em;
    }

    .form-control {
        padding: 10px 12px;
        border: 1px solid #ddd;
        border-radius: 4px;
        font-family: inherit;
        font-size: 1em;
    }

    .form-control:focus {
        outline: none;
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    }

    .rich-text-editor {
        border: 1px solid #ddd;
        border-radius: 4px;
    }

    .form-actions {
        display: flex;
        gap: 10px;
        margin-top: 30px;
        justify-content: flex-start;
    }

    .btn {
        padding: 12px 24px;
        font-size: 1em;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        transition: all 0.3s;
    }

    .btn-primary {
        background: #667eea;
        color: white;
    }

    .btn-primary:hover {
        background: #5568d3;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
    }

    .btn-secondary {
        background: #f0f0f0;
        color: #333;
    }

    .btn-secondary:hover {
        background: #e0e0e0;
    }

    .btn-lg {
        padding: 14px 28px;
        font-size: 1.1em;
    }
</style>
