@using AcademicManager.Domain.Entities
@using AcademicManager.Application.Services
@using AcademicManager.Web.Components.Forms
@inject EvaluacionService EvaluacionService
@inject IJSRuntime JS

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3>📊 Rúbrica de Evaluación</h3>
        <button class="btn btn-primary" @onclick="ShowCreateModal">
            + Nueva Evaluación
        </button>
    </div>
    <div class="card-body">
        @if (evaluaciones == null)
        {
            <p>Cargando...</p>
        }
        else if (!evaluaciones.Any())
        {
            <div class="alert alert-info">
                No hay evaluaciones definidas. Comienza agregando una (ej: Parcial 1, Tarea).
            </div>
        }
        else
        {
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Descripción</th>
                        <th>Peso %</th>
                        <th>Max. Puntaje</th>
                        <th>Fecha</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in evaluaciones)
                    {
                        <tr>
                            <td>@item.Nombre</td>
                            <td>@item.Descripcion</td>
                            <td>@item.Peso %</td>
                            <td>@item.MaximoPuntaje</td>
                            <td>@item.FechaEvaluacion.ToShortDateString()</td>
                            <td>
                                <button class="btn btn-sm btn-ghost" @onclick="() => Edit(item)">✏️</button>
                                <button class="btn btn-sm btn-ghost text-danger" @onclick="() => Delete(item.Id)">🗑️</button>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr class="fw-bold">
                        <td colspan="2" class="text-right">Total Peso:</td>
                        <td class="@(totalPeso != 100 ? "text-warning" : "text-success")">
                            @totalPeso %
                        </td>
                        <td colspan="3"></td>
                    </tr>
                </tfoot>
            </table>
        }
    </div>
</div>

@if (showModal)
{
    <div class="modal-overlay">
        <div class="modal">
            <div class="modal-header">
                <h4>@(editingItem.Id == 0 ? "Nueva Evaluación" : "Editar Evaluación")</h4>
                <button class="btn-close" @onclick="CloseModal">✕</button>
            </div>
            <CustomEditForm Model="editingItem" OnValidSubmit="Save">
                <DataAnnotationsValidator />
                <div class="modal-body">
                    <div class="form-group">
                        <label>Nombre</label>
                        <InputText class="form-control" @bind-Value="editingItem.Nombre" placeholder="Ej: Examen Parcial" />
                    </div>
                    <div class="form-group">
                        <label>Descripción</label>
                        <InputTextArea class="form-control" @bind-Value="editingItem.Descripcion" />
                    </div>
                    <div class="row">
                        <div class="col-6 form-group">
                            <label>Peso (%)</label>
                            <InputNumber class="form-control" @bind-Value="editingItem.Peso" />
                        </div>
                        <div class="col-6 form-group">
                            <label>Puntaje Máximo</label>
                            <InputNumber class="form-control" @bind-Value="editingItem.MaximoPuntaje" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Fecha Evaluación</label>
                        <InputDate class="form-control" @bind-Value="editingItem.FechaEvaluacion" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Guardar</button>
                </div>
            </CustomEditForm>
        </div>
    </div>
}

@code {
    [Parameter] public int PlanificacionId { get; set; }
    
    private List<Evaluacion> evaluaciones = new();
    private Evaluacion editingItem = new();
    private bool showModal = false;
    private decimal totalPeso => evaluaciones?.Sum(e => e.Peso) ?? 0;

    protected override async Task OnParametersSetAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        if (PlanificacionId > 0)
        {
            evaluaciones = (await EvaluacionService.GetByPlanificacionIdAsync(PlanificacionId)).ToList();
        }
    }

    private void ShowCreateModal()
    {
        editingItem = new Evaluacion 
        { 
            PlanificacionId = PlanificacionId, 
            FechaEvaluacion = DateTime.Today,
            MaximoPuntaje = 20 // Default grading scale
        };
        showModal = true;
    }

    private void Edit(Evaluacion item)
    {
        editingItem = new Evaluacion
        {
            Id = item.Id,
            PlanificacionId = item.PlanificacionId,
            Nombre = item.Nombre,
            Descripcion = item.Descripcion,
            Peso = item.Peso,
            MaximoPuntaje = item.MaximoPuntaje,
            FechaEvaluacion = item.FechaEvaluacion,
            Activo = item.Activo
        };
        showModal = true;
    }

    private void CloseModal() => showModal = false;

    private async Task Save()
    {
        if (editingItem.Id == 0)
            await EvaluacionService.CreateAsync(editingItem);
        else
            await EvaluacionService.UpdateAsync(editingItem);
            
        showModal = false;
        await LoadData();
    }

    private async Task Delete(int id)
    {
        if (await JS.InvokeAsync<bool>("confirm", "Confirma eliminar esta evaluación?"))
        {
            await EvaluacionService.DeleteAsync(id);
            await LoadData();
        }
    }
}
