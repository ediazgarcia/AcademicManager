@inherits LayoutComponentBase
@using AcademicManager.Web.Services.Authentication
@inject NavigationManager Navigation
@inject IHttpContextAccessor HttpContextAccessor
@inject CustomAuthenticationStateProvider AuthStateProvider

<div class="app-layout @(sidebarCollapsed ? "sidebar-collapsed" : "") @(sidebarOpen ? "sidebar-mobile-open" : "")">
    <!-- 🏝️ Sidebar Island -->
    <aside class="sidebar">
        <div class="sidebar-header">
            <div class="brand-logo">
                <span class="logo-icon">🎓</span>
            </div>
            <div class="brand-text @(sidebarCollapsed ? "hidden" : "")">
                <h2>Academic</h2>
                <span>Manager</span>
            </div>
            <SidebarCollapseButton Collapsed="sidebarCollapsed" OnToggle="ToggleCollapse" />
        </div>

        <nav class="sidebar-nav">
            <!-- Principal -->
            <div class="nav-section-title @(sidebarCollapsed ? "hidden" : "")">Principal</div>
            <NavLink class="nav-item" href="/" Match="NavLinkMatch.All">
                <span class="nav-icon">📊</span>
                <span class="nav-text @(sidebarCollapsed ? "hidden" : "")">Dashboard</span>
            </NavLink>

            <!-- Administración (Solo Admin) -->
            @if (currentRole == "Admin")
            {
                <div class="nav-section-title @(sidebarCollapsed ? "hidden" : "")">Administración</div>
                <NavLink class="nav-item" href="/periodos">
                    <span class="nav-icon">📅</span>
                    <span class="nav-text @(sidebarCollapsed ? "hidden" : "")">Periodos</span>
                </NavLink>
                <NavLink class="nav-item" href="/grados">
                    <span class="nav-icon">🏫</span>
                    <span class="nav-text @(sidebarCollapsed ? "hidden" : "")">Grados</span>
                </NavLink>
                <NavLink class="nav-item" href="/secciones">
                    <span class="nav-icon">📋</span>
                    <span class="nav-text @(sidebarCollapsed ? "hidden" : "")">Secciones</span>
                </NavLink>
                <NavLink class="nav-item" href="/usuarios">
                    <span class="nav-icon">👥</span>
                    <span class="nav-text @(sidebarCollapsed ? "hidden" : "")">Usuarios</span>
                </NavLink>
            }

            <!-- Académico -->
            <div class="nav-section-title @(sidebarCollapsed ? "hidden" : "")">Académico</div>
            
            @if (currentRole == "Admin")
            {
                <NavLink class="nav-item" href="/alumnos">
                    <span class="nav-icon">👨‍🎓</span>
                    <span class="nav-text @(sidebarCollapsed ? "hidden" : "")">Alumnos</span>
                </NavLink>
                <NavLink class="nav-item" href="/docentes">
                    <span class="nav-icon">👨‍🏫</span>
                    <span class="nav-text @(sidebarCollapsed ? "hidden" : "")">Docentes</span>
                </NavLink>
                <NavLink class="nav-item" href="/cursos">
                    <span class="nav-icon">📚</span>
                    <span class="nav-text @(sidebarCollapsed ? "hidden" : "")">Cursos</span>
                </NavLink>
            }
            else if (currentRole == "Docente")
            {
                <NavLink class="nav-item" href="/alumnos">
                    <span class="nav-icon">👨‍🎓</span>
                    <span class="nav-text @(sidebarCollapsed ? "hidden" : "")">Alumnos</span>
                </NavLink>
                <NavLink class="nav-item" href="/cursos">
                    <span class="nav-icon">📚</span>
                    <span class="nav-text @(sidebarCollapsed ? "hidden" : "")">Cursos</span>
                </NavLink>
            }
            else
            {
                <NavLink class="nav-item" href="/alumnos">
                    <span class="nav-icon">👨‍🎓</span>
                    <span class="nav-text @(sidebarCollapsed ? "hidden" : "")">Alumnos</span>
                </NavLink>
                <NavLink class="nav-item" href="/cursos">
                    <span class="nav-icon">📚</span>
                    <span class="nav-text @(sidebarCollapsed ? "hidden" : "")">Cursos</span>
                </NavLink>
            }
            
            <NavLink class="nav-item" href="/horarios">
                <span class="nav-icon">🕐</span>
                <span class="nav-text @(sidebarCollapsed ? "hidden" : "")">Horarios</span>
            </NavLink>

            <!-- Planificación -->
            <div class="nav-section-title @(sidebarCollapsed ? "hidden" : "")">Planificación</div>
            
            <NavLink class="nav-item nav-item-featured" href="/planificador">
                <span class="nav-icon">🗓️</span>
                <span class="nav-text @(sidebarCollapsed ? "hidden" : "")">Mi Planificador</span>
            </NavLink>
        </nav>

        <!-- Sidebar Footer -->
        <div class="sidebar-footer">
            <UserMenu Collapsed="sidebarCollapsed" />
        </div>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
        <!-- Minimal Topbar -->
        <header class="topbar">
            <div class="topbar-left">
                <div class="breadcrumb">
                    <SidebarToggle OnToggle="ToggleSidebarMobile" />
                    <span class="breadcrumb-separator">/</span>
                    <span class="breadcrumb-text">@GetPageTitle()</span>
                </div>
            </div>
            <div class="topbar-right">
                <div class="status-indicator">
                    <span class="status-dot"></span>
                    <span>En línea</span>
                </div>
            </div>
        </header>

        <!-- Page Content -->
        <div class="page-content">
            @Body
        </div>
    </main>

    <MobileOverlay Visible="sidebarOpen" OnClick="ToggleSidebarMobile" />
</div>

<!-- Global Notifications -->
@* <Notifications /> *@

@code {
    private bool sidebarOpen = false;
    private bool sidebarCollapsed = false;
    private string currentUser = "";
    private string currentRole = "";

    protected override async Task OnInitializedAsync()
    {
        var session = HttpContextAccessor.HttpContext?.Session;
        currentUser = session?.GetString("UserName") ?? "";
        currentRole = session?.GetString("UserRole") ?? "";

        if (string.IsNullOrEmpty(currentUser))
        {
            await Task.Yield();
            Navigation.NavigateTo("/login", forceLoad: true);
        }
    }

    private void ToggleSidebarMobile() => sidebarOpen = !sidebarOpen;
    private void ToggleCollapse() 
    {
        sidebarCollapsed = !sidebarCollapsed;
    }

    private string GetPageTitle()
    {
        var path = Navigation.ToBaseRelativePath(Navigation.Uri);
        if (string.IsNullOrEmpty(path)) return "Dashboard";
        
        return System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(path.Replace("-", " "));
    }
}
