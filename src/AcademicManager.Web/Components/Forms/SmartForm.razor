@typeparam TItem

<CustomEditForm Model="@Model" OnValidSubmit="@HandleValidSubmit" FormName="@FormName" class="@FormClass">
    <DataAnnotationsValidator />
    
    @if (ShowValidationSummary)
    {
        <ValidationSummary class="alert alert-warning" />
    }
    
    @ChildContent
    
    @if (ShowFooter)
    {
        <div class="form-footer mt-3">
            @if (ShowCancelButton)
            {
                <button type="button" class="btn btn-secondary" @onclick="@HandleCancel" disabled="@IsSubmitting">
                    @CancelText
                </button>
            }
            
            @if (ShowSubmitButton)
            {
                <button type="submit" class="@SubmitButtonClass" disabled="@IsSubmitting">
                    @if (IsSubmitting)
                    {
                        <span class="spinner spinner-sm me-2"></span>
                        <span>@SubmittingText</span>
                    }
                    else
                    {
                        <span>@SubmitText</span>
                    }
                </button>
            }
        </div>
    }
</CustomEditForm>

@code {
    [Parameter]
    public TItem? Model { get; set; }

    [Parameter]
    public EventCallback<TItem> ModelChanged { get; set; }

    [Parameter]
    public EventCallback<EditContext> OnSubmit { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public string? FormName { get; set; }

    [Parameter]
    public string FormClass { get; set; } = "form";

    [Parameter]
    public bool IsSubmitting { get; set; }

    [Parameter]
    public bool ShowFooter { get; set; } = true;

    [Parameter]
    public bool ShowCancelButton { get; set; } = true;

    [Parameter]
    public bool ShowSubmitButton { get; set; } = true;

    [Parameter]
    public bool ShowValidationSummary { get; set; } = false;

    [Parameter]
    public string SubmitText { get; set; } = "Guardar";

    [Parameter]
    public string SubmittingText { get; set; } = "Guardando...";

    [Parameter]
    public string CancelText { get; set; } = "Cancelar";

    [Parameter]
    public string SubmitButtonClass { get; set; } = "btn btn-primary";

    private async Task HandleValidSubmit()
    {
        if (OnSubmit.HasDelegate)
        {
            await OnSubmit.InvokeAsync(new EditContext(Model!));
        }
    }

    private async Task HandleCancel()
    {
        if (OnCancel.HasDelegate)
        {
            await OnCancel.InvokeAsync();
        }
    }
}