@namespace AcademicManager.Web.Components.Grading
@using AcademicManager.Application.DTOs

@* Component for selecting and applying feedback templates *@
<div class="feedback-template-selector">
    <div class="selector-header">
        <h5>Plantillas de Retroalimentación</h5>
        @if (HasTemplates)
        {
            <span class="template-count">@Templates.Count disponibles</span>
        }
    </div>

    @if (!HasTemplates)
    {
        <div class="ops-empty">
            <p>No hay plantillas disponibles. <a href="/profesores/plantillas">Crear una</a></p>
        </div>
    }
    else
    {
        <div class="template-buttons">
            @foreach (var template in Templates)
            {
                <button type="button"
                        class="template-btn"
                        title="@template.Contenido"
                        @onclick="() => OnTemplateSelected(template)">
                    <span class="template-icon">📝</span>
                    <span class="template-title">@template.Titulo</span>
                </button>
            }
        </div>

        <div class="template-preview">
            @if (SelectedTemplate != null)
            {
                <div class="preview-header">
                    <strong>Vista previa:</strong>
                </div>
                <div class="preview-content">
                    @SelectedTemplate.Contenido
                </div>
                <div class="preview-actions">
                    <button type="button" class="btn btn-sm btn-primary" @onclick="OnApplyTemplate">
                        Aplicar
                    </button>
                    <button type="button" class="btn btn-sm btn-secondary" @onclick="() => SelectedTemplate = null">
                        Cerrar
                    </button>
                </div>
            }
        </div>
    }
</div>

@code {
    /// <summary>
    /// Available feedback templates
    /// </summary>
    [Parameter]
    public List<FeedbackTemplateDto> Templates { get; set; } = new();

    /// <summary>
    /// Callback when template is applied
    /// </summary>
    [Parameter]
    public EventCallback<FeedbackTemplateDto> OnApply { get; set; }

    private FeedbackTemplateDto SelectedTemplate { get; set; }

    private bool HasTemplates => Templates != null && Templates.Any();

    private async Task OnTemplateSelected(FeedbackTemplateDto template)
    {
        SelectedTemplate = template;
    }

    private async Task OnApplyTemplate()
    {
        if (SelectedTemplate != null)
        {
            await OnApply.InvokeAsync(SelectedTemplate);
            SelectedTemplate = null;
        }
    }

    public class FeedbackTemplateDto
    {
        public int Id { get; set; }
        public string Titulo { get; set; }
        public string Contenido { get; set; }
        public string Materia { get; set; }
    }
}

<style>
    .feedback-template-selector {
        padding: 1.5rem;
        background: var(--workspace-panel);
        border-radius: var(--workspace-radius-md);
        border: 1px solid var(--workspace-border);
    }

    .selector-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid var(--workspace-border);
    }

    .selector-header h5 {
        margin: 0;
        font-size: 0.95rem;
        font-weight: 600;
    }

    .template-count {
        display: inline-block;
        padding: 0.25rem 0.75rem;
        background: rgba(15, 140, 121, 0.1);
        border-radius: 0.25rem;
        font-size: 0.75rem;
        color: #0f8c79;
        font-weight: 600;
    }

    .template-buttons {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 1rem;
    }

    .template-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        background: white;
        border: 1px solid var(--workspace-border);
        border-radius: var(--workspace-radius-sm);
        cursor: pointer;
        font-size: 0.875rem;
        font-weight: 500;
        transition: all 0.2s;
    }

    .template-btn:hover {
        background: #f9f9f9;
        border-color: #0f8c79;
        color: #0f8c79;
    }

    .template-icon {
        font-size: 1rem;
    }

    .template-title {
        max-width: 200px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .template-preview {
        margin-top: 1rem;
        padding: 1rem;
        background: white;
        border: 1px solid var(--workspace-border);
        border-radius: var(--workspace-radius-sm);
    }

    .preview-header {
        margin-bottom: 0.75rem;
        font-size: 0.875rem;
        color: var(--workspace-text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .preview-content {
        padding: 1rem;
        background: #f9f9f9;
        border: 1px dashed var(--workspace-border);
        border-radius: 0.25rem;
        font-size: 0.875rem;
        line-height: 1.5;
        margin-bottom: 1rem;
        white-space: pre-wrap;
        word-wrap: break-word;
    }

    .preview-actions {
        display: flex;
        gap: 0.75rem;
        justify-content: flex-end;
    }

    .btn {
        padding: 0.5rem 1rem;
        border-radius: var(--workspace-radius-sm);
        border: 1px solid var(--workspace-border);
        cursor: pointer;
        font-weight: 600;
        font-size: 0.875rem;
        transition: all 0.2s;
    }

    .btn-primary {
        background: #0f8c79;
        color: white;
        border-color: #0f8c79;
    }

    .btn-primary:hover {
        background: #0a6b5a;
        border-color: #0a6b5a;
    }

    .btn-secondary {
        background: white;
        color: var(--workspace-text);
        border-color: var(--workspace-border);
    }

    .btn-secondary:hover {
        background: #f5f5f5;
    }

    .btn-sm {
        padding: 0.35rem 0.7rem;
        font-size: 0.8rem;
    }
</style>
